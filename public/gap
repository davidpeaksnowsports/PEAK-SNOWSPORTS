<div id="chrome">
  <div class="ctrl" id="prev" title="Previous (Left arrow)">&#8249;</div>
  <div class="dots" id="dots"></div>
  <div class="ctrl" id="next" title="Next (Right arrow)">&#8250;</div>
  <span id="count">01 / 13</span>
  <div class="ctrl" id="play" title="Autoplay">&#9654;</div>
  <div class="ctrl" id="full" title="Fullscreen (F)">&#9974;</div>
</div>

<script>
const stage=document.getElementById('stage');
const slides=[...document.querySelectorAll('[data-slide]')];
const N=slides.length;
let cur=0, playing=false, timer=null;
const DW=1280, DH=720;

/* scale to fit */
function fit(){
  const vw=window.innerWidth, vh=window.innerHeight-56;
  const s=Math.min(vw/DW, vh/DH)*0.97;
  stage.style.transform='scale('+s+')';
  document.getElementById('fit').style.width=(DW*s)+'px';
  document.getElementById('fit').style.height=(DH*s)+'px';
}
window.addEventListener('resize',fit); fit();

/* dots */
const dotsWrap=document.getElementById('dots');
slides.forEach((_,i)=>{const d=document.createElement('div');d.className='dot';d.onclick=()=>go(i);dotsWrap.appendChild(d);});
const dots=[...document.querySelectorAll('.dot')];

function runCounters(slide){
  slide.querySelectorAll('[data-count]').forEach(el=>{
    const target=+el.getAttribute('data-count');
    const pre=el.getAttribute('data-prefix')||'';
    const suf=el.getAttribute('data-suffix')||'';
    const comma=el.getAttribute('data-comma');
    const dur=900; const t0=performance.now();
    function frame(t){
      const p=Math.min(1,(t-t0)/dur);
      const e=1-Math.pow(1-p,3);
      let v=Math.round(target*e);
      let str=comma?v.toLocaleString('en-US'):v;
      el.innerHTML=pre+str+suf;
      if(p<1) requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  });
}

function go(i){
  if(i<0)i=N-1; if(i>=N)i=0;
  const old=cur; cur=i;
  if(old!==i){
    slides[old].classList.add('leaving');
    slides[old].classList.remove('active');
    setTimeout(()=>slides[old].classList.remove('leaving'),450);
  }
  const s=slides[i];
  // restart reveal animations
  s.classList.remove('active'); void s.offsetWidth; s.classList.add('active');
  setTimeout(()=>runCounters(s), 260);
  dots.forEach((d,k)=>d.classList.toggle('on',k===i));
  document.getElementById('count').textContent=String(i+1).padStart(2,'0')+' / '+String(N).padStart(2,'0');
  document.getElementById('prog').style.width=((i+1)/N*100)+'%';
}

function next(){go(cur+1);} function prev(){go(cur-1);}

document.getElementById('next').onclick=()=>{stopPlay();next();};
document.getElementById('prev').onclick=()=>{stopPlay();prev();};
document.getElementById('full').onclick=()=>{
  if(!document.fullscreenElement) document.documentElement.requestFullscreen(); else document.exitFullscreen();
};
function startPlay(){playing=true;document.getElementById('play').innerHTML='&#10074;&#10074;';timer=setInterval(next,6500);}
function stopPlay(){playing=false;document.getElementById('play').innerHTML='&#9654;';clearInterval(timer);}
document.getElementById('play').onclick=()=>{playing?stopPlay():startPlay();};

document.addEventListener('keydown',e=>{
  if(['ArrowRight',' ','PageDown'].includes(e.key)){e.preventDefault();stopPlay();next();}
  else if(['ArrowLeft','PageUp'].includes(e.key)){e.preventDefault();stopPlay();prev();}
  else if(e.key==='Home'){stopPlay();go(0);}
  else if(e.key==='End'){stopPlay();go(N-1);}
  else if(e.key==='f'||e.key==='F'){document.getElementById('full').click();}
});

/* click stage to advance (ignore links/controls) */
stage.addEventListener('click',e=>{
  if(e.target.closest('a')) return;
  const rect=stage.getBoundingClientRect();
  if(e.clientX < rect.left+rect.width*0.18){stopPlay();prev();} else {stopPlay();next();}
});

/* swipe */
let tx=0;
stage.addEventListener('touchstart',e=>tx=e.touches[0].clientX,{passive:true});
stage.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>40){stopPlay();dx<0?next():prev();}},{passive:true});

/* hide hint after a bit */
setTimeout(()=>{document.getElementById('hint').style.opacity=0;},5000);

go(0);
</script>
