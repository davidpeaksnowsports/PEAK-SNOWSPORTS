<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#15212D;
  --navy-2:#101A24;
  --card-navy:#17314A;
  --card-navy-2:#142A40;
  --cream:#FAF9F4;
  --cream-band:#ECE5D6;
  --ink:#181D24;
  --on-navy:#F1EEE7;
  --on-navy-mute:#94A1AE;
  --on-cream-mute:#5C6470;
  --pink:#EE2E6E;
  --pink-soft:rgba(238,46,110,.16);
  --DW:1280px; --DH:720px;
  --ease:cubic-bezier(.22,.61,.36,1);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{
  background:#07090C;
  font-family:'Hanken Grotesk',system-ui,sans-serif;
  color:var(--ink);
  overflow:hidden;
  -webkit-font-smoothing:antialiased;
}
/* ---------- letterbox + scaling ---------- */
#viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;}
#fit{position:relative;}
#stage{
  position:relative;
  width:var(--DW);height:var(--DH);
  transform-origin:center center;
  overflow:hidden;
  border-radius:6px;
  box-shadow:0 40px 120px -30px rgba(0,0,0,.7);
}
.slide{
  position:absolute;inset:0;
  opacity:0;visibility:hidden;pointer-events:none;
  transition:opacity .5s var(--ease), transform .55s var(--ease);
  transform:translateX(26px);
  padding:54px 64px 50px;
}
.slide.active{opacity:1;visibility:visible;pointer-events:auto;transform:none;}
.slide.leaving{opacity:0;visibility:visible;transform:translateX(-26px);transition:opacity .35s ease, transform .4s var(--ease);}
.bg-navy{background:var(--navy);color:var(--on-navy);}
.bg-cream{background:var(--cream);color:var(--ink);}

/* ---------- reveal system ---------- */
[data-r]{opacity:0;transform:translateY(22px);transition:opacity .6s var(--ease),transform .6s var(--ease);transition-delay:var(--d,0ms);}
.active [data-r]{opacity:1;transform:none;}
[data-r="dash"]{transform-origin:left center;transform:scaleX(0);transition:transform .5s var(--ease);transition-delay:var(--d,0ms);}
.active [data-r="dash"]{transform:scaleX(1);}
[data-r="bar-x"]{transform-origin:left center;transform:scaleX(0);transition:transform .6s var(--ease);transition-delay:var(--d,0ms);}
.active [data-r="bar-x"]{transform:scaleX(1);}
[data-r="bar-y"]{transform-origin:top center;transform:scaleY(0);transition:transform .6s var(--ease);transition-delay:var(--d,0ms);}
.active [data-r="bar-y"]{transform:scaleY(1);}
[data-r="img"]{opacity:0;transform:scale(1.08);transition:opacity .9s var(--ease),transform 1.1s var(--ease);transition-delay:var(--d,0ms);}
.active [data-r="img"]{opacity:1;transform:none;}

/* ---------- typography ---------- */
.eyebrow{display:flex;align-items:center;gap:16px;font-weight:700;font-size:14px;letter-spacing:.14em;text-transform:uppercase;color:var(--pink);}
.eyebrow .dash{width:34px;height:3px;background:var(--pink);display:block;border-radius:2px;}
h1.display{font-weight:800;letter-spacing:-.022em;line-height:.96;margin-top:36px;}
.lead{font-weight:400;color:var(--on-cream-mute);line-height:1.4;}
.bg-navy .lead{color:var(--on-navy-mute);}
.pink{color:var(--pink);}
.foot{position:absolute;left:64px;right:64px;bottom:24px;display:flex;justify-content:space-between;
  font-size:13.5px;color:var(--on-cream-mute);border-top:1px solid rgba(0,0,0,.10);padding-top:14px;}
.bg-navy .foot{color:var(--on-navy-mute);border-top:1px solid rgba(255,255,255,.10);}

/* ---------- slide 1 ---------- */
.s1{padding:0;display:grid;grid-template-columns:1fr 38%;}
.s1 .left{padding:58px 60px;display:flex;flex-direction:column;justify-content:center;position:relative;}
.s1 .logo{position:absolute;top:54px;left:60px;width:104px;height:104px;}
.s1 h1{font-size:74px;margin-top:0;}
.s1 .sub{margin-top:26px;max-width:560px;font-size:19px;line-height:1.45;color:var(--on-navy-mute);}
.s1 .rule{margin-top:34px;height:1px;width:520px;max-width:70%;background:linear-gradient(90deg,rgba(241,238,231,.5),rgba(241,238,231,0));}
.s1 .badges{margin-top:18px;font-size:13px;letter-spacing:.07em;color:var(--on-navy-mute);text-transform:uppercase;font-weight:600;}
.s1 .photo{position:relative;overflow:hidden;border-left:5px solid var(--pink);}
.s1 .photo img{width:100%;height:100%;object-fit:cover;display:block;}
.kenburns{animation:kb 16s ease-in-out infinite alternate;}
@keyframes kb{from{transform:scale(1.02) translate(0,0)}to{transform:scale(1.12) translate(-1.5%,-2%)}}

/* ---------- slide 2 opportunity ---------- */
.s2{display:grid;grid-template-columns:1fr 33%;gap:46px;align-items:start;}
.s2 h1{font-size:58px;margin-top:24px;}
.s2 .lead{margin-top:22px;font-size:19px;max-width:560px;}
.points{margin-top:30px;display:flex;flex-direction:column;gap:20px;}
.pt{display:grid;grid-template-columns:262px 1fr;gap:8px;align-items:baseline;}
.pt .sq{display:inline-block;width:9px;height:9px;background:var(--pink);margin-right:12px;vertical-align:middle;}
.pt b{font-size:18px;font-weight:700;}
.pt span{font-size:15.5px;color:var(--on-cream-mute);line-height:1.4;}
.s2 .imgwrap{margin-top:120px;aspect-ratio:1/1;border-radius:8px;overflow:hidden;outline:2px dashed #cfc9bb;outline-offset:6px;}
.s2 .imgwrap img{width:100%;height:100%;object-fit:cover;display:block;}

/* ---------- slide 3 cards ---------- */
.s3 h1{font-size:64px;}
.s3 .lead{margin-top:14px;font-size:19px;max-width:730px;}
.cards4{margin-top:40px;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.card{position:relative;background:var(--card-navy-2);border-radius:8px;padding:26px 22px 24px;min-height:188px;overflow:hidden;}
.card .top{position:absolute;top:0;left:0;right:0;height:4px;background:var(--pink);}
.card h3{font-size:21px;font-weight:700;line-height:1.1;color:var(--on-navy);}
.card p{margin-top:14px;font-size:14.5px;line-height:1.42;color:var(--on-navy-mute);}
.s3 .closing{position:absolute;left:64px;bottom:64px;font-size:17px;color:var(--on-navy-mute);}

/* ---------- slide 4 stats ---------- */
.s4 h1{font-size:54px;}
.stats{margin-top:64px;display:grid;grid-template-columns:repeat(4,1fr);}
.stat{padding:0 6px;position:relative;}
.stat:not(:first-child){border-left:1px solid rgba(0,0,0,.12);padding-left:34px;}
.stat .num{font-size:74px;font-weight:800;color:var(--pink);line-height:.9;letter-spacing:-.02em;}
.stat .unit{font-size:30px;font-weight:800;color:var(--ink);margin-top:2px;letter-spacing:-.01em;}
.stat .lab{margin-top:18px;font-size:13.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--on-cream-mute);}
.band{position:absolute;left:64px;right:64px;bottom:78px;background:var(--cream-band);border-radius:8px;
  display:grid;grid-template-columns:repeat(4,1fr);padding:22px 10px;}
.band div{text-align:center;font-size:16px;color:var(--ink);}

/* ---------- slide 5 two ways ---------- */
.s5 h1{font-size:64px;}
.cards2{margin-top:40px;display:grid;grid-template-columns:1fr 1fr;gap:34px;}
.bigcard{position:relative;background:var(--card-navy-2);border-radius:8px;padding:32px 34px;min-height:300px;}
.bigcard .lbar{position:absolute;top:0;bottom:0;left:0;width:5px;background:var(--pink);border-radius:5px 0 0 5px;}
.bigcard .tag{font-size:14px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--pink);}
.bigcard h3{margin-top:14px;font-size:38px;font-weight:800;color:var(--on-navy);letter-spacing:-.02em;}
.bigcard .date{margin-top:8px;font-size:21px;color:var(--on-navy);}
.bigcard .prov{font-size:14px;color:var(--on-navy-mute);margin-top:2px;}
.bigcard p{margin-top:22px;font-size:16px;line-height:1.5;color:var(--on-navy-mute);}
.s5 .strip{position:absolute;left:0;right:0;bottom:74px;text-align:center;font-weight:700;letter-spacing:.06em;
  color:var(--pink);font-size:16px;}

/* ---------- slide 6 reasons ---------- */
.s6 h1{font-size:62px;}
.reasons{margin-top:42px;display:grid;grid-template-columns:1fr 1fr;gap:36px 70px;}
.reason{display:grid;grid-template-columns:64px 1fr;gap:18px;}
.reason .n{font-size:40px;font-weight:800;color:var(--pink);line-height:1;}
.reason .body{border-left:1px solid rgba(0,0,0,.16);padding-left:20px;}
.reason h3{font-size:23px;font-weight:700;color:var(--ink);}
.reason p{margin-top:8px;font-size:15.5px;line-height:1.45;color:var(--on-cream-mute);}

/* ---------- slide 7 included ---------- */
.s7 h1{font-size:54px;line-height:1.0;}
.cols4{margin-top:40px;display:grid;grid-template-columns:repeat(4,1fr);gap:30px;}
.col h4{font-size:21px;font-weight:700;color:var(--on-navy);padding-top:16px;position:relative;}
.col h4::before{content:"";position:absolute;top:0;left:0;width:26px;height:3px;background:var(--pink);border-radius:2px;}
.col ul{list-style:none;margin-top:18px;display:flex;flex-direction:column;gap:11px;}
.col li{font-size:14.5px;line-height:1.35;color:var(--on-navy-mute);padding-left:16px;position:relative;}
.col li::before{content:"";position:absolute;left:0;top:7px;width:6px;height:6px;background:var(--pink);}
.s7 .note{position:absolute;left:64px;bottom:64px;font-size:14px;color:var(--on-navy-mute);padding-left:16px;}
.s7 .note::before{content:"";position:absolute;left:0;top:7px;width:6px;height:6px;background:var(--on-navy-mute);}

/* ---------- slide 8 life ---------- */
.s8 h1{font-size:58px;}
.s8 .lead{margin-top:18px;font-size:19px;max-width:760px;}
.gallery{margin-top:36px;display:grid;grid-template-columns:1.5fr 1fr 1.5fr;gap:18px;height:300px;}
.gallery figure{border-radius:8px;overflow:hidden;outline:2px dashed #cfc9bb;outline-offset:5px;}
.gallery img{width:100%;height:100%;object-fit:cover;display:block;}

/* ---------- slide 9 travels ---------- */
.s9 h1{font-size:62px;}
.rows{margin-top:44px;}
.row9{display:grid;grid-template-columns:300px 1fr;gap:20px;padding:18px 0;border-bottom:1px solid rgba(241,238,231,.13);align-items:baseline;}
.row9 .k{font-size:25px;font-weight:700;color:var(--pink);}
.row9 .v{font-size:19px;color:var(--on-navy);line-height:1.4;}
.s9 .note{position:absolute;left:64px;right:64px;bottom:74px;font-size:16px;color:var(--on-navy-mute);line-height:1.4;}

/* ---------- slide 10 investment ---------- */
.s10 h1{font-size:62px;}
.cards2.invest{margin-top:34px;}
.icard{position:relative;background:var(--cream-band);border-radius:8px;padding:28px 32px;min-height:150px;}
.icard .lbar{position:absolute;top:0;bottom:0;left:0;width:5px;background:var(--pink);border-radius:5px 0 0 5px;}
.icard .h{display:flex;justify-content:space-between;align-items:center;}
.icard h3{font-size:24px;font-weight:700;color:var(--ink);}
.icard .pill{background:var(--pink);color:#fff;font-size:12px;font-weight:700;letter-spacing:.06em;padding:5px 12px;border-radius:20px;}
.icard .price{font-size:54px;font-weight:800;color:var(--pink);letter-spacing:-.02em;margin-top:6px;}
.icard p{margin-top:6px;font-size:15px;color:var(--on-cream-mute);line-height:1.4;}
.subs{margin-top:24px;display:grid;grid-template-columns:repeat(3,1fr);gap:30px;}
.sub b{font-size:18px;font-weight:700;color:var(--ink);}
.sub p{margin-top:6px;font-size:14.5px;color:var(--on-cream-mute);line-height:1.4;}
.s10 .mz{margin-top:14px;font-size:13px;color:#9a9384;padding-left:14px;position:relative;}
.s10 .mz::before{content:"";position:absolute;left:0;top:7px;width:5px;height:5px;background:#b9b1a0;}
.earlybird{position:absolute;left:64px;right:64px;bottom:74px;background:var(--navy);color:var(--on-navy);
  border-radius:8px;padding:20px 28px;display:flex;gap:24px;align-items:center;}
.earlybird .tag{color:var(--pink);font-weight:700;letter-spacing:.06em;font-size:14px;white-space:nowrap;}
.earlybird .txt{font-size:18px;}

/* ---------- slide 11 between us ---------- */
.s11 h1{font-size:58px;line-height:1.0;}
.twocol{margin-top:40px;display:grid;grid-template-columns:1fr 1fr;gap:30px 80px;}
.note11{display:grid;grid-template-columns:34px 1fr;gap:6px;}
.note11 .d{width:26px;height:3px;background:var(--pink);border-radius:2px;margin-top:11px;}
.note11 h3{font-size:21px;font-weight:700;color:var(--on-navy);}
.note11 p{margin-top:8px;font-size:15px;line-height:1.42;color:var(--on-navy-mute);}

/* ---------- slide 12 faq ---------- */
.s12 h1{font-size:62px;}
.faq{margin-top:44px;display:grid;grid-template-columns:1fr 1fr;gap:42px 70px;}
.qa h3{font-size:25px;font-weight:700;color:var(--ink);}
.qa p{margin-top:12px;font-size:16px;line-height:1.5;color:var(--on-cream-mute);}

/* ---------- slide 13 cta ---------- */
.s13 .logo{position:absolute;top:50px;right:60px;width:118px;height:118px;}
.s13 h1{font-size:84px;margin-top:30px;}
.s13 .lead{margin-top:22px;font-size:21px;max-width:560px;}
.ctas{margin-top:48px;display:flex;gap:22px;}
.cta{border:1.5px solid var(--pink);border-radius:40px;padding:18px 30px;min-width:230px;text-decoration:none;display:block;transition:transform .25s var(--ease),background .25s;}
.cta:hover{transform:translateY(-3px);}
.cta.filled{background:var(--pink);}
.cta b{display:block;font-size:18px;font-weight:700;color:var(--on-navy);}
.cta span{display:block;margin-top:3px;font-size:14px;color:var(--on-navy-mute);}
.cta.filled b{color:#fff;}.cta.filled span{color:rgba(255,255,255,.85);}
.s13 .contact{position:absolute;left:64px;right:64px;bottom:54px;padding-top:24px;border-top:1px solid rgba(241,238,231,.14);}
.s13 .contact .em{font-size:18px;color:var(--on-navy);}
.s13 .contact .deal{margin-top:12px;font-size:14px;font-weight:700;letter-spacing:.06em;color:var(--pink);}
.s13 .contact .com{margin-top:10px;font-size:16px;color:var(--on-navy-mute);}

/* ---------- chrome ---------- */
#chrome{position:fixed;left:0;right:0;bottom:0;height:56px;display:flex;align-items:center;justify-content:center;gap:18px;
  background:linear-gradient(0deg,rgba(0,0,0,.55),transparent);z-index:50;opacity:.92;transition:opacity .3s;}
#chrome:hover{opacity:1;}
.ctrl{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);color:#E9ECEF;border-radius:8px;
  width:38px;height:34px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;
  transition:background .2s,border-color .2s;}
.ctrl:hover{background:var(--pink);border-color:var(--pink);color:#fff;}
.dots{display:flex;gap:9px;align-items:center;padding:0 6px;}
.dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.28);cursor:pointer;transition:all .25s;}
.dot.on{background:var(--pink);transform:scale(1.35);}
#count{color:#C7CCD2;font-size:13px;font-variant-numeric:tabular-nums;letter-spacing:.04em;min-width:54px;text-align:center;}
#prog{position:fixed;left:0;top:0;height:3px;background:var(--pink);width:0;z-index:60;transition:width .5s var(--ease);}
#hint{position:fixed;top:14px;right:18px;z-index:60;color:rgba(255,255,255,.55);font-size:12px;letter-spacing:.03em;
  transition:opacity .6s;}

@media (prefers-reduced-motion: reduce){
  [data-r],[data-r="dash"],[data-r="bar-x"],[data-r="bar-y"],[data-r="img"]{transition:none!important;opacity:1!important;transform:none!important;}
  .kenburns{animation:none!important;}
  .slide{transition:opacity .2s linear!important;}
}
</style>
</head>
<body>
<div id="prog"></div>
<div id="hint">&larr; &rarr; or click to navigate &middot; F fullscreen</div>
<div id="viewport"><div id="fit"><div id="stage">

<!-- ============ SLIDE 1 ============ -->
<section class="slide bg-navy s1" data-slide>
  <div class="left">
    <img class="logo" data-r style="--d:80ms" src="data:image/png;base64," alt="Peak Snowsports">
    <h1 class="display">
      <span data-r style="--d:220ms;display:block">Six weeks.</span>
      <span data-r style="--d:330ms;display:block">From skier to</span>
      <span class="pink" data-r style="--d:440ms;display:block">instructor.</span>
    </h1>
    <p class="sub" data-r style="--d:600ms">Two intakes a year, pre-season in Hintertux, Austria, or in-season in Morzine-Avoriaz. Same course, coached by the people who run BASI exams.</p>
    <div class="rule" data-r style="--d:720ms"></div>
    <div class="badges" data-r style="--d:800ms">BASI Business Partner &middot; Tripadvisor Travellers' Choice 2026 &middot; Family run business</div>
  </div>
  <div class="photo"><img data-r="img" style="--d:120ms" class="kenburns" src="data:image/jpeg;base64," alt=""></div>
</section>

<!-- ============ SLIDE 2 ============ -->
<section class="slide bg-cream s2" data-slide>
  <div>
    <div class="eyebrow" data-r style="--d:60ms"><span class="dash" data-r="dash" style="--d:60ms"></span>The opportunity</div>
    <h1 class="display" data-r style="--d:180ms">Turn one course<br><span class="pink">into a career.</span></h1>
    <p class="lead" data-r style="--d:300ms">Most people who love skiing never make it pay. This is the fast, structured route from confident skier to qualified, employable instructor, six focused weeks, not a whole gap year of guesswork.</p>
    <div class="points">
      <div class="pt" data-r style="--d:420ms"><b><span class="sq"></span>A real qualification.</b><span>BASI Level 1 + Level 2 &mdash; the recognised route into paid instructing across the Alps and beyond.</span></div>
      <div class="pt" data-r style="--d:520ms"><b><span class="sq"></span>Coached by the examiners.</b><span>You train with the people who set and run the BASI standard, so nothing on assessment day is a surprise.</span></div>
      <div class="pt" data-r style="--d:620ms"><b><span class="sq"></span>A job offer at the end.</b><span>Partner ski schools interview on-course and take our Level 2 instructors directly.</span></div>
    </div>
  </div>
  <div class="imgwrap" data-r="img" style="--d:360ms"><img src="data:image/jpeg;base64," alt=""></div>
  <div class="foot"><span>Peak Snowsports &middot; BASI GAP Course</span><span>2026 / 27 &middot; 02</span></div>
</section>

<!-- ============ SLIDE 3 ============ -->
<section class="slide bg-navy s3" data-slide>
  <div class="eyebrow" data-r style="--d:60ms"><span class="dash" data-r="dash" style="--d:60ms"></span>Who you'll train with</div>
  <h1 class="display" data-r style="--d:170ms">PEAK Snowsports.</h1>
  <p class="lead" data-r style="--d:280ms">A premium ski school in the heart of the Portes du Soleil, and a BASI Business Partner, approved to deliver and examine BASI training to the official standard.</p>
  <div class="cards4">
    <div class="card" data-r style="--d:400ms"><span class="top" data-r="bar-x" style="--d:480ms"></span><h3>BASI Business Partner</h3><p>Approved to deliver and assess Level 1 and Level 2 to the official BASI standard.</p></div>
    <div class="card" data-r style="--d:480ms"><span class="top" data-r="bar-x" style="--d:560ms"></span><h3>Coaches who examine</h3><p>Current BASI trainers lead every session, the people who score the assessments.</p></div>
    <div class="card" data-r style="--d:560ms"><span class="top" data-r="bar-x" style="--d:640ms"></span><h3>Travellers' Choice 2026</h3><p>Tripadvisor Travellers' Choice Winner, recognised by guests across the season.</p></div>
