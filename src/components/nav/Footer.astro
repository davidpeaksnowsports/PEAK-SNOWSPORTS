---
const cols = [
  {
    title: 'Peak',
    links: [
      { href: '/about', label: 'About' },
      { href: '/journal', label: 'Journal' },
      { href: '/instructors', label: 'Instructors' },
    ],
  },
  {
    title: 'Book',
    links: [
      { href: '/lessons', label: 'Lessons' },
      { href: '/gap-course', label: 'GAP Course' },
      { href: '/book', label: 'Booking widget' },
    ],
  },
  {
    title: 'Resorts',
    links: [
      { href: '/resorts/morzine', label: 'Morzine' },
      { href: '/resorts/chatel', label: 'Chatel' },
      { href: '/resorts/les-gets', label: 'Les Gets' },
    ],
  },
  {
    title: 'Help',
    links: [
      { href: '/contact', label: 'Contact' },
      { href: '/faqs', label: 'FAQs' },
      { href: '/partners', label: 'Partner enquiries' },
    ],
  },
];
---

<footer class="mt-32 border-t border-olive/10 bg-snow">
  <div class="mx-auto grid max-w-screen-2xl gap-12 px-6 py-16 md:grid-cols-5">
    <div class="md:col-span-2">
      <p class="meta text-yellow">peak snowsports</p>
      <p class="mt-4 max-w-sm text-sm text-olive/70">
        Morzine · Chatel · Les Gets. We don't run lessons. We build skiers.
      </p>
      <form class="mt-8 flex max-w-sm gap-2">
        <input
          type="email"
          placeholder="email@example.com"
          class="flex-1 border-b border-olive/30 bg-transparent py-2 text-sm placeholder:text-olive/40 focus:border-yellow focus:outline-none"
          aria-label="Email for newsletter"
        />
        <button class="meta rounded-full border border-olive/30 px-3 py-2 hover:border-yellow hover:text-yellow">
          Subscribe
        </button>
      </form>
    </div>

    {cols.map((col) => (
      <div>
        <p class="meta text-olive/50">{col.title}</p>
        <ul class="mt-4 space-y-2">
          {col.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm no-underline hover:text-yellow">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-olive/10">
    <div class="mx-auto max-w-screen-2xl px-6 py-10">
      <p class="meta text-olive/40">Partners</p>
      <div class="mt-6 flex flex-wrap items-center gap-x-12 gap-y-6">
        <img
          src="/images/logos/basi.svg"
          alt="BASI — British Association of Snowsport Instructors"
          class="h-8 w-auto opacity-80"
        />
        <img
          src="/images/logos/peak-performance.png"
          alt="Peak Performance"
          class="h-6 w-auto opacity-80"
        />
        <img
          src="/images/logos/douglas-elliman.jpg"
          alt="Douglas Elliman"
          class="h-7 w-auto opacity-90"
        />
      </div>
    </div>
  </div>

  <div class="border-t border-olive/10">
    <div class="mx-auto flex max-w-screen-2xl flex-col gap-4 px-6 py-6 text-xs text-olive/50 md:flex-row md:items-center md:justify-between">
      <p>&copy; {new Date().getFullYear()} Peak Snowsports. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="no-underline hover:text-yellow">Privacy</a>
        <a href="/terms" class="no-underline hover:text-yellow">T&amp;Cs</a>
      </div>
    </div>
  </div>
</footer>
