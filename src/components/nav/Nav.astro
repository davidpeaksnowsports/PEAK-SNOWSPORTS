---
const primary = [
  { href: '/lessons', label: 'Lessons' },
  { href: '/ski-camps', label: 'Ski Camps' },
  { href: '/gap-course', label: 'GAP Course' },
  { href: '/resorts', label: 'Resorts' },
  { href: '/instructors', label: 'Instructors' },
  { href: '/journal', label: 'Journal' },
  { href: '/about', label: 'About' },
];

const secondary = [
  { href: '/book', label: 'Book' },
  { href: '/book', label: 'Account' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-olive/10 bg-snow/80 backdrop-blur">
  <div class="mx-auto flex max-w-screen-2xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center no-underline" aria-label="Peak Snowsports, home">
      <img src="/images/logos/peak-menu-logo.png" alt="Peak Snowsports" class="h-10 w-auto md:h-12" />
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {primary.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-4 py-2 font-display text-base font-bold uppercase tracking-tight no-underline transition hover:bg-yellow hover:text-olive-deep"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 md:flex">
      {secondary.map((item) => (
        <a href={item.href} class="meta -mx-1 rounded px-1 no-underline transition-colors hover:bg-yellow">{item.label}</a>
      ))}
      <span class="meta text-olive/60">EN / FR</span>
    </div>

    <button
      id="nav-open"
      type="button"
      class="md:hidden meta flex items-center gap-1.5 rounded-full border border-olive/20 px-4 py-2"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      Menu
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <rect y="2" width="14" height="1.5" rx="0.75" fill="currentColor"/>
        <rect y="6.25" width="14" height="1.5" rx="0.75" fill="currentColor"/>
        <rect y="10.5" width="14" height="1.5" rx="0.75" fill="currentColor"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex flex-col bg-snow md:hidden"
  aria-hidden="true"
  style="display:none"
>
  <!-- Header row inside drawer -->
  <div class="flex items-center justify-between border-b border-olive/10 px-6 py-4">
    <a href="/" class="flex items-center no-underline" aria-label="Peak Snowsports, home">
      <img src="/images/logos/peak-menu-logo.png" alt="Peak Snowsports" class="h-10 w-auto" />
    </a>
    <button
      id="nav-close"
      type="button"
      class="meta flex items-center gap-1.5 rounded-full border border-olive/20 px-4 py-2"
      aria-label="Close menu"
    >
      Close
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex flex-col px-6 py-8 gap-1 flex-1 overflow-y-auto">
    {primary.map((item) => (
      <a
        href={item.href}
        class="rounded-2xl px-4 py-4 font-display text-2xl font-bold uppercase tracking-tight no-underline transition hover:bg-pink hover:text-salt"
      >
        {item.label}
      </a>
    ))}
  </nav>

  <!-- Secondary links at bottom -->
  <div class="border-t border-olive/10 px-6 py-6 flex items-center gap-6">
    {secondary.map((item) => (
      <a href={item.href} class="meta no-underline transition-colors hover:text-pink">{item.label}</a>
    ))}
    <span class="meta text-olive/40 ml-auto">EN / FR</span>
  </div>
</div>

<script>
  const openBtn = document.getElementById('nav-open');
  const closeBtn = document.getElementById('nav-close');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu!.style.display = 'flex';
    menu!.setAttribute('aria-hidden', 'false');
    openBtn!.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu!.style.display = 'none';
    menu!.setAttribute('aria-hidden', 'true');
    openBtn!.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
