---
const primary = [
  { href: '/lessons', label: 'Lessons' },
  { href: '/ski-camps', label: 'Ski Camps' },
  { href: '/gap-course', label: 'GAP Course' },
  { href: '/resorts', label: 'Resorts' },
  { href: '/instructors', label: 'Instructors' },
  { href: '/journal', label: 'Journal' },
  { href: '/about', label: 'About' },
];

const secondary = [
  { href: '/book', label: 'Book' },
  { href: '/book', label: 'Account' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-olive/10 bg-snow/80 backdrop-blur">
  <div class="mx-auto flex max-w-screen-2xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center no-underline" aria-label="Peak Snowsports, home">
      <img src="/images/logos/peak-menu-logo.png" alt="Peak Snowsports" class="h-10 w-auto md:h-12" />
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {primary.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-4 py-2 font-display text-base font-bold uppercase tracking-tight no-underline transition hover:bg-yellow hover:text-olive-deep"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 md:flex">
      {secondary.map((item) => (
        <a href={item.href} class="meta -mx-1 rounded px-1 no-underline transition-colors hover:bg-yellow">{item.label}</a>
      ))}
      <span class="meta text-olive/60">EN / FR</span>
    </div>

    <button
      type="button"
      class="md:hidden meta"
      aria-label="Open menu"
    >
      Menu
    </button>
  </div>
</header>
