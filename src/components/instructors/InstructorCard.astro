---
interface Props {
  name: string;
  role?: string;
  resort?: string;          // deprecated, kept for back-compat
  resorts?: string[];       // preferred: full list of resorts this instructor works at
  speciality?: string;
  photo?: string;
  href?: string;
}

const { name, role, resort, resorts, speciality, photo, href = '#' } = Astro.props;

// Build the resort label. Prefer `resorts` array; fall back to single `resort` prop.
const resortList = resorts && resorts.length ? resorts : (resort ? [resort] : []);
const resortLabel = resortList.join(' · ');
---

<a href={href} class="group block no-underline">
  <div class="aspect-[3/4] w-full overflow-hidden rounded-2xl bg-brown">
    {photo ? (
      <img
        src={photo}
        alt={name}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center">
        <span class="meta text-salt/30">portrait pending</span>
      </div>
    )}
  </div>
  <div class="mt-4">
    {resortLabel && (
      <span class="meta inline-block rounded-sm bg-pink px-2 py-1 text-snow">{resortLabel}</span>
    )}
    <h3 class="mt-3 text-lg font-semibold leading-tight group-hover:underline">{name}</h3>
    {(role || speciality) && (
      <p class="mt-1 text-sm text-olive/65">{speciality ?? role}</p>
    )}
  </div>
</a>
