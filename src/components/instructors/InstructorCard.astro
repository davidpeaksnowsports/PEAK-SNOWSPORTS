---
interface Props {
  name: string;
  resort?: string;
  speciality?: string;
  href?: string;
}

const { name, resort, speciality, href = '#' } = Astro.props;
---

<a href={href} class="group block no-underline">
  <div class="aspect-[3/4] w-full bg-brown" aria-hidden="true">
    <!-- Instructor portrait — same lighting / same crop convention. -->
  </div>
  <div class="mt-4">
    <p class="meta text-salt/50">{resort ?? 'Morzine'}</p>
    <h3 class="mt-1 text-lg font-semibold group-hover:text-yellow">{name}</h3>
    {speciality && <p class="mt-1 text-sm text-salt/60">{speciality}</p>}
  </div>
</a>
