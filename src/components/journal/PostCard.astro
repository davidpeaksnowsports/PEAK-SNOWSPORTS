---
interface Props {
  title: string;
  category?: string;
  author?: string;
  date?: string;
  href?: string;
}

const { title, category, author, date, href = '#' } = Astro.props;
---

<a href={href} class="group block no-underline">
  <div class="aspect-[16/10] w-full overflow-hidden rounded-2xl bg-brown" aria-hidden="true" />
  <div class="mt-6">
    <span class="meta inline-flex items-center rounded-full bg-yellow px-3 py-1 text-olive-deep">
      {category ?? 'Journal'}
    </span>
    <h3 class="mt-4 text-xl font-semibold leading-snug underline-offset-4 group-hover:underline md:text-2xl">{title}</h3>
    {(author || date) && (
      <p class="meta mt-4 text-olive/50">
        {author && <span>{author}</span>}
        {author && date && <span class="px-2">·</span>}
        {date && <span>{date}</span>}
      </p>
    )}
  </div>
</a>
