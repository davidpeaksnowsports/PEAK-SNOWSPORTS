---
interface Props {
  href?: string;
  kicker?: string;
  title: string;
  class?: string;
}

const { href, kicker, title, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class={`group block border border-salt/10 bg-olive p-8 no-underline transition hover:border-yellow ${className}`}
>
  {kicker && <p class="meta text-yellow">{kicker}</p>}
  <h3 class="mt-4 text-2xl font-semibold leading-tight">{title}</h3>
  <div class="mt-4 text-sm text-salt/70">
    <slot />
  </div>
</Tag>
