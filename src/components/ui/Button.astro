---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: className = '', ...rest } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline transition';
const variants = {
  primary: 'bg-yellow text-navy-deep hover:bg-salt',
  secondary: 'border border-salt/40 text-salt hover:border-yellow hover:text-yellow',
  ghost: 'text-salt hover:text-yellow',
};

const cls = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={cls} {...rest}><slot /></a>
) : (
  <button class={cls} {...rest}><slot /></button>
)}
