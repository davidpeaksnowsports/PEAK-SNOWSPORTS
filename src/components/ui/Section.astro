---
interface Props {
  kicker?: string;
  title?: string;
  class?: string;
  id?: string;
}

const { kicker, title, class: className = '', id } = Astro.props;
---

<section id={id} class={`px-6 py-24 md:py-32 ${className}`}>
  <div class="mx-auto max-w-screen-2xl">
    {(kicker || title) && (
      <header class="mb-12 max-w-3xl">
        {kicker && <p class="meta text-yellow">{kicker}</p>}
        {title && <h2 class="mt-4 text-4xl font-semibold leading-tight md:text-6xl">{title}</h2>}
      </header>
    )}
    <slot />
  </div>
</section>
