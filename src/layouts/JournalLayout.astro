---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  author?: string;
  date?: string;
  hero?: string;       // path under /public, e.g. "/images/journal/foo.jpg"
  heroAlt?: string;
  readingMinutes?: number;
}

const {
  title,
  description,
  category,
  author,
  date,
  hero,
  heroAlt = '',
  readingMinutes,
} = Astro.props;
---

<BaseLayout title={`${title} — Peak Journal`} description={description}>
  <article class="px-6 pb-24 pt-16 md:pb-32 md:pt-24">
    <header class="mx-auto max-w-3xl">
      {category && (
        <a
          href={`/journal/category/${category.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
          class="meta inline-flex items-center rounded-full bg-yellow px-3 py-1 text-olive-deep no-underline transition hover:bg-salt"
        >
          {category}
        </a>
      )}
      <h1 class="mt-6 text-4xl leading-tight md:text-6xl">{title}</h1>
      <p class="meta mt-6 flex flex-wrap items-center gap-x-2 text-olive/60">
        {author && <span>{author}</span>}
        {author && date && <span>·</span>}
        {date && <span>{date}</span>}
        {(author || date) && readingMinutes && <span>·</span>}
        {readingMinutes && <span>{readingMinutes} min read</span>}
      </p>
    </header>

    {hero ? (
      <img
        src={hero}
        alt={heroAlt}
        class="mx-auto mt-16 aspect-[16/9] max-w-5xl rounded-3xl object-cover"
      />
    ) : (
      <div class="mx-auto mt-16 aspect-[16/9] max-w-5xl overflow-hidden rounded-3xl bg-brown" aria-hidden="true" />
    )}

    <div class="article-prose prose prose-lg mx-auto mt-16 max-w-2xl
      prose-headings:font-display prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-olive
      prose-h2:mt-12 prose-h2:text-3xl md:prose-h2:text-4xl
      prose-h3:text-2xl
      prose-p:text-olive/80
      prose-li:text-olive/80 prose-li:marker:text-olive/40
      prose-strong:text-olive
      prose-a:text-olive prose-a:underline-offset-4 hover:prose-a:bg-yellow
      prose-blockquote:border-l-yellow prose-blockquote:not-italic prose-blockquote:font-display prose-blockquote:font-semibold prose-blockquote:text-olive
      prose-img:rounded-2xl">
      <slot />
    </div>
  </article>
</BaseLayout>
