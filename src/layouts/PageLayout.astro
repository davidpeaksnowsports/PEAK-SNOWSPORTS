---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';

interface Props {
  title?: string;
  description?: string;
  kicker?: string;
  headline: string;
  sub?: string;
  variant?: 'full' | 'compact';
}

const { title, description, kicker, headline, sub, variant = 'compact' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Hero kicker={kicker} headline={headline} sub={sub} variant={variant} />
  <article class="px-6 py-24 md:py-32">
    <div class="mx-auto max-w-3xl space-y-8 text-lg leading-relaxed text-olive/80">
      <slot />
    </div>
  </article>
</BaseLayout>
