---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import { Content } from '../data/privacy.md';
---

<BaseLayout
  title="Privacy Notice — Peak Snowsports"
  description="How and why Peak Snowsports collects, stores, uses, and shares your personal information, and the privacy rights you have."
>
  <Hero
    kicker="Legal"
    headline="Privacy Notice"
    sub="How and why we collect, use, and protect your personal information — and the rights you have over it. Last updated June 01, 2022."
    variant="compact"
  />

  <article class="px-6 py-24 md:py-32">
    <div
      class="prose prose-lg mx-auto max-w-3xl
             prose-headings:font-display prose-headings:tracking-tight prose-headings:text-olive
             prose-h2:mt-20 prose-h2:text-3xl prose-h2:font-bold md:prose-h2:text-4xl
             prose-h3:mt-12 prose-h3:text-2xl prose-h3:font-bold
             prose-p:text-olive/80 prose-li:text-olive/80
             prose-a:text-olive prose-a:underline-offset-4 hover:prose-a:text-yellow
             prose-strong:text-olive"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
