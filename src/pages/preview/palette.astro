---
/**
 * Throwaway palette preview — strict 3-colour palette, accent-forward.
 * Mostly white surface. Accent used boldly: display type, full-width
 * panels, large shapes, generous deployment. Black used minimally
 * (just type on white).
 *
 * Delete this file once a palette decision is made.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const WHITE = '#FFFFFF';
const BLACK = '#0A0A0A';

const swatches = [
  {
    name: 'Peach-tan',
    hex: '#f0bd7c',
    note: 'Warm, premium, sophisticated.',
  },
  {
    name: 'Hot pink',
    hex: '#eb437f',
    note: 'Bold, modern, anti-bland.',
  },
];
---

<BaseLayout title="Palette preview — Peak Snowsports">
  <article class="px-6 py-12 md:py-16" style={`background-color:${WHITE}; color:${BLACK};`}>
    <div class="mx-auto max-w-screen-2xl">
      <p class="meta" style="opacity:0.5;">Internal · palette preview · accent-forward · summer collection</p>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Two contenders. Pick one.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed md:text-xl" style="opacity:0.85;">
        Strict 3-colour palette, but the accent does <em class="italic">real</em> work — display headlines, full-width bands, big shapes, generous panels. Mostly white surface. Black is reserved for body type. No olive, no yellow, no brown, no salt.
      </p>

      <div class="mt-12 grid gap-12 lg:grid-cols-2 lg:gap-10">
        {swatches.map((s) => (
          <section class="overflow-hidden rounded-3xl" style={`border:1px solid ${BLACK};`}>

            <!-- Swatch header -->
            <header class="flex items-center justify-between gap-6 px-8 py-6" style={`border-bottom:1px solid ${BLACK}; background-color:${WHITE};`}>
              <div>
                <p class="meta" style="opacity:0.5;">Option</p>
                <h2 class="mt-1 font-display text-2xl font-bold tracking-tight md:text-3xl">{s.name}</h2>
                <p class="meta mt-1" style="opacity:0.6;">{s.hex} · white · black</p>
              </div>
              <span class="block h-16 w-16 rounded-full" style={`background-color:${s.hex};`}></span>
            </header>

            <!-- 1. Hero (WHITE bg, BLACK display headline, ACCENT massive accent shape behind it) -->
            <div class="relative overflow-hidden px-8 py-16 md:px-10 md:py-20" style={`background-color:${WHITE}; color:${BLACK};`}>
              <!-- Big accent circle in corner — accent at scale -->
              <span
                class="absolute -right-24 -top-24 block h-72 w-72 rounded-full md:-right-16 md:-top-16 md:h-96 md:w-96"
                style={`background-color:${s.hex};`}
                aria-hidden="true"
              ></span>
              <div class="relative">
                <p class="meta" style={`color:${s.hex}; background-color:${BLACK}; display:inline-block; padding:0.25rem 0.5rem;`}>Adult ski camps</p>
                <h3 class="mt-4 font-display text-4xl font-bold leading-[0.95] tracking-tight md:text-6xl">
                  Five days on snow.<br/>
                  <span style={`color:${s.hex}; background-color:${BLACK}; padding:0 0.3em;`}>One serious step up.</span>
                </h3>
                <p class="mt-6 max-w-md text-base md:text-lg" style="opacity:0.8;">
                  Small-group ski camps for intermediate and advanced skiers. Coached by BASI Trainers.
                </p>
                <div class="mt-8 flex flex-wrap gap-3">
                  <a
                    href="#"
                    class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline"
                    style={`background-color:${s.hex}; color:${BLACK};`}
                  >
                    Reserve your place
                  </a>
                  <a
                    href="#"
                    class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline"
                    style={`border:2px solid ${s.hex}; color:${BLACK};`}
                    onmouseover={`this.style.backgroundColor='${s.hex}';`}
                    onmouseout="this.style.backgroundColor='';"
                  >
                    See the camps
                  </a>
                </div>
              </div>
            </div>

            <!-- 2. FULL-WIDTH ACCENT BAND — accent at maximum scale -->
            <div class="px-8 py-14 md:px-10 md:py-20" style={`background-color:${s.hex}; color:${BLACK};`}>
              <p class="meta" style={`color:${BLACK}; opacity:0.7;`}>What you get</p>
              <h3 class="mt-3 font-display text-3xl font-bold leading-[0.95] tracking-tight md:text-5xl">
                Eight skiers max.<br/>Five hours on snow.<br/>BASI Trainers.
              </h3>
              <ul class="mt-8 grid gap-3 text-base md:grid-cols-2 md:text-lg">
                <li>· Performance video analysis</li>
                <li>· Full Portes du Soleil pass</li>
                <li>· Equipment workshops</li>
                <li>· Lunches in the best spots</li>
              </ul>
            </div>

            <!-- 3. White section with accent kickers, accent badge, accent inline highlights -->
            <div class="px-8 py-14 md:px-10 md:py-20" style={`background-color:${WHITE}; color:${BLACK};`}>
              <p class="meta" style={`color:${s.hex};`}>Why students choose Peak</p>
              <h3 class="mt-3 font-display text-2xl font-bold leading-tight tracking-tight md:text-4xl">
                Real progression through seven levels.
              </h3>
              <p class="mt-6 max-w-2xl text-base leading-relaxed md:text-lg" style="opacity:0.85;">
                You learn faster because we never lose track of you. Eight skiers max — and the same coaches who train other instructors are coaching you. <a href="#" class="underline-offset-4 hover:underline" style={`color:${BLACK}; text-decoration-color:${s.hex}; text-decoration-thickness:3px;`}>Read more about how we coach.</a>
              </p>

              <!-- Numbered badge + heading -->
              <div class="mt-10 flex items-start gap-5">
                <span
                  class="meta inline-flex h-14 w-14 items-center justify-center rounded-full"
                  style={`background-color:${s.hex}; color:${BLACK};`}
                >01</span>
                <div>
                  <h4 class="font-display text-xl font-bold tracking-tight md:text-2xl">Eight building blocks</h4>
                  <p class="mt-2 max-w-md text-base" style="opacity:0.8;">The six essentials behind every good skier.</p>
                </div>
              </div>

              <!-- Hover highlight -->
              <p class="meta mt-10" style="opacity:0.6;">
                Hover-link pattern:
                <a
                  href="#"
                  class="ml-1 inline-block px-1 transition-colors"
                  style="text-decoration:none; color:inherit;"
                  onmouseover={`this.style.backgroundColor='${s.hex}';`}
                  onmouseout="this.style.backgroundColor='';"
                >hover this text</a>
                · highlight in the accent.
              </p>
            </div>

            <!-- 4. Card-grid moment — accent cards on white -->
            <div class="px-8 py-12 md:px-10 md:py-16" style={`background-color:${WHITE};`}>
              <p class="meta" style={`color:${s.hex};`}>Two durations</p>
              <h3 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">Pick the right length.</h3>
              <div class="mt-8 grid gap-4 sm:grid-cols-2">
                <article class="rounded-2xl p-6" style={`background-color:${s.hex}; color:${BLACK};`}>
                  <p class="meta" style="opacity:0.7;">Ages 5–7</p>
                  <p class="mt-2 font-display text-2xl font-bold tracking-tight">3 hours</p>
                  <p class="mt-2 text-sm" style="opacity:0.85;">Right length for shorter attention spans.</p>
                </article>
                <article class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK}; border:2px solid ${s.hex};`}>
                  <p class="meta" style={`color:${s.hex};`}>Ages 7–12</p>
                  <p class="mt-2 font-display text-2xl font-bold tracking-tight">4 hours</p>
                  <p class="mt-2 text-sm" style="opacity:0.85;">A full half-day on snow.</p>
                </article>
              </div>
            </div>

            <!-- 5. Inverted card (accent type on black surface — testing accent visibility on dark too) -->
            <div class="px-8 py-12 md:px-10 md:py-16" style={`background-color:${WHITE};`}>
              <article class="rounded-3xl p-8 md:p-10" style={`background-color:${BLACK}; color:${WHITE};`}>
                <p class="meta" style={`color:${s.hex};`}>Ready to book</p>
                <h4 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">
                  Pick a camp. Hold your place.
                </h4>
                <p class="mt-4 text-base md:text-lg" style="opacity:0.85;">
                  Confirm with a small refundable deposit.
                </p>
                <a
                  href="#"
                  class="mt-6 inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline"
                  style={`background-color:${s.hex}; color:${BLACK};`}
                >
                  Check availability →
                </a>
              </article>
            </div>

            <!-- Footnote -->
            <footer class="px-8 py-4" style={`border-top:1px solid ${BLACK}; background-color:${WHITE};`}>
              <p class="meta" style="opacity:0.6;">{s.note}</p>
            </footer>
          </section>
        ))}
      </div>

      <div class="mt-20 max-w-3xl pt-12" style={`border-top:1px solid ${BLACK};`}>
        <p class="meta" style="opacity:0.55;">Where the accent now lives</p>
        <h2 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">
          The accent does real work
        </h2>
        <ul class="mt-6 space-y-2 text-base md:text-lg" style="opacity:0.85;">
          <li>· Full-width accent bands as section dividers</li>
          <li>· Big accent shapes behind hero headlines (the circle in the corner)</li>
          <li>· Inline accent backgrounds inside the headline itself (the "step up" highlight)</li>
          <li>· Accent kickers everywhere they used to be faded grey/olive</li>
          <li>· Accent-coloured borders on outline buttons and cards (replacing dark borders)</li>
          <li>· Accent decoration on links (3px underline)</li>
          <li>· Numbered badges and pill chips</li>
          <li>· Hover-highlight on inline links</li>
          <li>· Card surfaces in the accent (vs the old dark-brown cards)</li>
        </ul>
      </div>
    </div>
  </article>
</BaseLayout>
