---
/**
 * Throwaway palette preview — pink-led with sparing blue & green.
 *
 * After feedback: drop wine, use blue + green sparingly. Pink does
 * the heavy lifting site-wide. Blue + green are reserved for
 * specific jobs (level coding, success states) and stay rare.
 *
 * Delete this file once a palette decision is made.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const WHITE = '#FFFFFF';
const BLACK = '#0A0A0A';

const PINK  = '#EB437F'; // primary accent — does ~80% of accent work
const BLUE  = '#2E55E2'; // sparing — only for distinct purposes (e.g. level coding)
const GREEN = '#1FB089'; // sparing — only for success / confirmation moments

const palette = [
  { name: 'White',  hex: WHITE, role: 'Primary surface' },
  { name: 'Black',  hex: BLACK, role: 'Body type · dark surfaces' },
  { name: 'Pink',   hex: PINK,  role: 'Primary accent · everywhere' },
  { name: 'Blue',   hex: BLUE,  role: 'Sparingly · level / category coding only' },
  { name: 'Green',  hex: GREEN, role: 'Sparingly · success / confirmation only' },
];
---

<BaseLayout title="Palette preview — Summer Collection">
  <article class="px-6 py-12 md:py-16" style={`background-color:${WHITE}; color:${BLACK};`}>
    <div class="mx-auto max-w-screen-2xl">
      <p class="meta" style="opacity:0.5;">Internal · palette preview · pink-led · summer collection</p>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Pink leads. <span style={`color:${PINK};`}>Always.</span>
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed md:text-xl" style="opacity:0.85;">
        Pink is the dominant accent — CTAs, kickers, hero highlights, badges, hover-bgs. Blue and green appear <em class="italic">rarely</em>, for specific jobs: blue codes levels/categories, green marks success and confirmation. That's it.
      </p>

      <!-- Swatches -->
      <ul class="mt-12 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
        {palette.map((c) => (
          <li class="rounded-2xl overflow-hidden" style={`border:1px solid ${BLACK};`}>
            <div class="h-24" style={`background-color:${c.hex};`}></div>
            <div class="p-4">
              <p class="meta" style="opacity:0.5;">{c.name}</p>
              <p class="mt-1 font-display text-base font-bold tracking-tight">{c.hex}</p>
              <p class="meta mt-2" style="opacity:0.75;">{c.role}</p>
            </div>
          </li>
        ))}
      </ul>

      <!-- 1. HERO — pink only -->
      <section class="mt-16 overflow-hidden rounded-3xl" style={`border:1px solid ${BLACK};`}>
        <div class="relative overflow-hidden px-8 py-16 md:px-12 md:py-24" style={`background-color:${WHITE}; color:${BLACK};`}>
          <span class="absolute -right-32 -top-32 block h-96 w-96 rounded-full" style={`background-color:${PINK};`} aria-hidden="true"></span>

          <div class="relative">
            <p class="meta" style={`background-color:${BLACK}; color:${PINK}; display:inline-block; padding:0.25rem 0.6rem;`}>Adult ski camps</p>
            <h2 class="mt-4 font-display text-4xl font-bold leading-[0.95] tracking-tight md:text-7xl">
              Five days on snow.<br/>
              <span style={`color:${WHITE}; background-color:${BLACK}; padding:0 0.3em;`}>One serious</span><br/>
              <span style={`color:${PINK};`}>step up.</span>
            </h2>
            <p class="mt-6 max-w-md text-base md:text-lg" style="opacity:0.85;">
              Small-group camps for intermediate and advanced skiers.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${PINK}; color:${WHITE};`}>Reserve your place</a>
              <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`border:2px solid ${BLACK}; color:${BLACK};`}>See the camps</a>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. LEVEL CARDS — the one place blue + green earn their keep -->
      <section class="mt-16">
        <p class="meta" style={`color:${PINK};`}>Pick your level</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">Where are you on the mountain?</h2>
        <p class="mt-4 max-w-2xl text-base md:text-lg" style="opacity:0.85;">
          Level coding is the one job blue and green are used for — it helps skiers scan-find their level fast. Beginner/improver in pink (warm, welcoming), intermediate in blue (cooler, deeper), advanced/expert in green/black (calm confidence).
        </p>

        <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <li class="rounded-2xl p-6" style={`background-color:${PINK}; color:${WHITE};`}>
            <p class="meta" style="opacity:0.85;">Level 01</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Beginner</h3>
            <p class="mt-2 text-sm" style="opacity:0.9;">Never skied before.</p>
          </li>
          <li class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK}; border:2px solid ${PINK};`}>
            <p class="meta" style={`color:${PINK};`}>Level 02</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Improver</h3>
            <p class="mt-2 text-sm" style="opacity:0.85;">Snowplough on green.</p>
          </li>
          <li class="rounded-2xl p-6" style={`background-color:${BLUE}; color:${WHITE};`}>
            <p class="meta" style="opacity:0.85;">Level 03</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Intermediate</h3>
            <p class="mt-2 text-sm" style="opacity:0.9;">Parallel on blues.</p>
          </li>
          <li class="rounded-2xl p-6" style={`background-color:${BLACK}; color:${WHITE};`}>
            <p class="meta" style={`color:${PINK};`}>Level 04</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Advanced</h3>
            <p class="mt-2 text-sm" style="opacity:0.9;">Any colour run.</p>
          </li>
        </ul>
      </section>

      <!-- 3. NUMBERS BAND — now BLACK surface (replaced wine), pink as the accent -->
      <section class="mt-16 overflow-hidden rounded-3xl p-10 md:p-16" style={`background-color:${BLACK}; color:${WHITE};`}>
        <p class="meta" style={`color:${PINK};`}>The numbers</p>
        <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Twenty thousand clients.<br/>
          Twenty-five instructors.<br/>
          <span style={`color:${PINK};`}>One school.</span>
        </h2>

        <div class="mt-12 grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK};`}>
            <p class="meta" style={`color:${PINK};`}>Coaching ratio</p>
            <p class="mt-2 font-display text-3xl font-bold tracking-tight">8:1 max</p>
          </div>
          <div class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK};`}>
            <p class="meta" style={`color:${PINK};`}>Length</p>
            <p class="mt-2 font-display text-3xl font-bold tracking-tight">5 days</p>
          </div>
          <div class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK};`}>
            <p class="meta" style={`color:${PINK};`}>Qualification</p>
            <p class="mt-2 font-display text-3xl font-bold tracking-tight">BASI Trainers</p>
          </div>
        </div>
      </section>

      <!-- 4. BODY SECTION — pink-led, single green flag as a 'confirmation' moment -->
      <section class="mt-16 px-2 md:px-0">
        <p class="meta" style={`color:${PINK};`}>Why students choose Peak</p>
        <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Coached by the people who train other instructors.
        </h2>
        <p class="mt-6 max-w-2xl text-base leading-relaxed md:text-lg" style="opacity:0.85;">
          You learn faster because we never lose track of you. The same coaches who run our
          <a href="#" class="px-1" style={`background-color:${PINK}; color:${WHITE}; text-decoration:none;`}>BASI courses</a>
          are coaching you. Eight skiers max. Read more about
          <a href="#" class="ml-1 underline-offset-4 underline" style={`color:${BLACK}; text-decoration-color:${PINK}; text-decoration-thickness:3px;`}>how we coach</a>.
        </p>

        <!-- Single green chip used for a 'confirmation' signal, otherwise pink throughout -->
        <p class="mt-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold" style={`background-color:${GREEN}; color:${WHITE};`}>
          <span aria-hidden="true">✓</span>
          Place confirmed
        </p>

        <!-- Numbered badges — all pink now (was rotating colours) -->
        <ol class="mt-10 space-y-8">
          {[
            { n: '01', t: 'Eight building blocks' },
            { n: '02', t: 'Ski-fit' },
            { n: '03', t: 'Performance analysis' },
          ].map((row) => (
            <li class="flex items-start gap-5">
              <span class="meta inline-flex h-14 w-14 items-center justify-center rounded-full" style={`background-color:${PINK}; color:${WHITE};`}>{row.n}</span>
              <div>
                <h4 class="font-display text-xl font-bold tracking-tight md:text-2xl">{row.t}</h4>
                <p class="mt-2 max-w-md text-base" style="opacity:0.8;">A line of supporting copy that explains the thing.</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- 5. CTA BAND — pink -->
      <section class="mt-16 overflow-hidden rounded-3xl p-10 md:p-16" style={`background-color:${PINK}; color:${WHITE};`}>
        <p class="meta" style={`color:${WHITE}; opacity:0.85;`}>Ready to book</p>
        <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Pick a camp. Hold your place.
        </h2>
        <p class="mt-4 max-w-md text-base md:text-lg" style="opacity:0.9;">
          Live availability. Refundable deposit. We confirm 6 weeks ahead.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${WHITE}; color:${BLACK};`}>Check availability →</a>
          <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`border:2px solid ${WHITE}; color:${WHITE};`}>Talk to us first</a>
        </div>
      </section>

      <!-- Notes -->
      <div class="mt-20 max-w-3xl pt-12" style={`border-top:1px solid ${BLACK};`}>
        <p class="meta" style="opacity:0.55;">Discipline: each colour stays in its lane</p>
        <h2 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">Pink-led, blue & green earn their keep</h2>
        <ul class="mt-6 space-y-3 text-base md:text-lg" style="opacity:0.85;">
          <li>· <strong style={`color:${PINK};`}>Pink</strong> is the brand. Every page anchors to it. CTAs / kickers / hero highlights / hover-bgs / underlines / badges all default to pink.</li>
          <li>· <strong style={`color:${BLUE};`}>Blue</strong> only appears for <em class="italic">level / category coding</em> — like the intermediate card above. Never as a CTA, never as a kicker. Rare moments.</li>
          <li>· <strong style={`color:${GREEN};`}>Green</strong> only appears for <em class="italic">confirmation / success</em> — booked, paid, confirmed, included. The chip above is the only one on this preview.</li>
          <li>· No wine surface — black does all dark-surface duty.</li>
        </ul>
        <p class="mt-6 max-w-2xl text-base md:text-lg" style="opacity:0.7;">
          Net result: most of the site is pink on white. Blue and green are flavour, not noise. You see them, you know what they mean.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
