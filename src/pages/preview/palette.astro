---
/**
 * Throwaway palette preview — comparing peach-tan vs hot-pink as the new
 * 'summer' accent against olive-deep type on snow.
 *
 * Delete this file once a palette decision is made.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const swatches = [
  {
    name: 'Peach-tan',
    hex: '#f0bd7c',
    note: 'Warm, premium, analogous to olive. Editorial.',
  },
  {
    name: 'Hot pink',
    hex: '#eb437f',
    note: 'Bold, modern, high-contrast. Energetic.',
  },
];

// Composite the type-on-snow contrast push too — sample uses olive-deep for body.
---

<BaseLayout title="Palette preview — Peak Snowsports">
  <article class="bg-snow px-6 py-16 md:py-24">
    <div class="mx-auto max-w-screen-2xl">
      <p class="meta text-olive-deep/55">Internal · palette preview</p>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight text-olive-deep md:text-6xl">
        Summer accent · two contenders.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-olive-deep/80 md:text-xl">
        Each panel below renders real Peak components — hero / kicker / button / hover-link / card — in the proposed accent. Body type is pushed to <strong class="font-semibold">olive-deep</strong> for the editorial bite from pavillon Carré de Baudouin.
      </p>

      <div class="mt-16 grid gap-10 lg:grid-cols-2">
        {swatches.map((s) => (
          <section class="overflow-hidden rounded-3xl border border-olive-deep/15">

            <!-- Swatch header -->
            <header class="flex items-center justify-between gap-6 border-b border-olive-deep/10 bg-snow px-8 py-6">
              <div>
                <p class="meta text-olive-deep/50">Option</p>
                <h2 class="mt-1 font-display text-2xl font-bold tracking-tight text-olive-deep md:text-3xl">{s.name}</h2>
                <p class="meta mt-1 text-olive-deep/60">{s.hex}</p>
              </div>
              <span class="block h-16 w-16 rounded-full" style={`background-color: ${s.hex};`}></span>
            </header>

            <!-- Hero mock (dark surface, accent kicker, accent button) -->
            <div class="relative bg-olive-deep px-8 py-12 text-salt md:px-10 md:py-16">
              <p class="meta" style={`color: ${s.hex};`}>Adult ski camps · Morzine-Avoriaz</p>
              <h3 class="mt-3 font-display text-3xl font-semibold leading-[0.95] tracking-tight md:text-5xl">
                Five days on snow.<br/>One serious step up.
              </h3>
              <p class="mt-5 max-w-md text-base text-salt/85 md:text-lg">
                Small-group ski camps for intermediate and advanced skiers.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a
                  href="#"
                  class="inline-flex items-center rounded-full px-5 py-3 text-sm font-semibold uppercase tracking-wider text-olive-deep no-underline"
                  style={`background-color: ${s.hex};`}
                >
                  Reserve your place
                </a>
                <a
                  href="#"
                  class="inline-flex items-center rounded-full border border-salt/40 px-5 py-3 text-sm font-semibold uppercase tracking-wider no-underline"
                  style={`--accent: ${s.hex};`}
                  onmouseover={`this.style.borderColor='${s.hex}'; this.style.color='${s.hex}';`}
                  onmouseout="this.style.borderColor=''; this.style.color='';"
                >
                  See the camps
                </a>
              </div>
            </div>

            <!-- Body section (snow surface, olive-deep type, accent details) -->
            <div class="bg-snow px-8 py-12 md:px-10 md:py-16">
              <p class="meta" style={`color: ${s.hex};`}>Welcome</p>
              <h3 class="mt-3 font-display text-2xl font-bold leading-tight tracking-tight text-olive-deep md:text-4xl">
                Coached by the people who train other instructors.
              </h3>
              <p class="mt-6 max-w-2xl text-base leading-relaxed text-olive-deep/85 md:text-lg">
                Real progression through seven levels. Eight skiers max. You learn faster because we never lose track of you.
              </p>

              <!-- Yellow circle badge replacement -->
              <div class="mt-10 flex items-start gap-5">
                <span
                  class="meta inline-flex h-14 w-14 items-center justify-center rounded-full text-olive-deep"
                  style={`background-color: ${s.hex};`}
                >01</span>
                <div>
                  <h4 class="font-display text-xl font-bold tracking-tight text-olive-deep md:text-2xl">Eight building blocks</h4>
                  <p class="mt-2 max-w-md text-base text-olive-deep/80">The six essentials behind every good skier.</p>
                </div>
              </div>

              <!-- Hover-highlight link -->
              <p class="meta mt-10 text-olive-deep/60">
                And the on-hover yellow-highlight pattern becomes
                <a
                  href="#"
                  class="ml-1 inline-block px-1 transition-colors"
                  onmouseover={`this.style.backgroundColor='${s.hex}';`}
                  onmouseout="this.style.backgroundColor='';"
                  style="color: inherit; text-decoration: none;"
                >this colour</a>
                on hover.
              </p>
            </div>

            <!-- Footnote -->
            <footer class="border-t border-olive-deep/10 bg-snow px-8 py-4">
              <p class="meta text-olive-deep/55">{s.note}</p>
            </footer>
          </section>
        ))}
      </div>

      <div class="mt-20 max-w-3xl border-t border-olive-deep/10 pt-12">
        <p class="meta text-olive-deep/55">Reference</p>
        <h2 class="mt-2 font-display text-2xl font-bold tracking-tight text-olive-deep md:text-3xl">
          What changes site-wide if we ship this
        </h2>
        <ul class="mt-6 space-y-3 text-base text-olive-deep/85 md:text-lg">
          <li>· <strong class="font-semibold">yellow</strong> token in tailwind.config.ts swaps to the chosen hex</li>
          <li>· Default body type colour shifts from <strong class="font-semibold">olive</strong> (#3B4131) to <strong class="font-semibold">olive-deep</strong> (#1B1F17)</li>
          <li>· 'Summer collection' tag added to footer fine print + About page</li>
          <li>· CLAUDE.md palette table updated</li>
          <li>· This preview page deleted</li>
        </ul>
      </div>
    </div>
  </article>
</BaseLayout>
