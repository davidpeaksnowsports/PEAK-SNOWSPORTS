---
/**
 * Throwaway palette preview — pink + cream + white + a fourth deep colour.
 * Two candidates: Charcoal Gray vs Navy Blue.
 *
 * Delete this file once a palette decision is made.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const WHITE = '#FFFFFF';
const CLOUD = '#F1ECE0';
const PINK  = '#EB437F';

const CHARCOAL = '#1F1F1F';
const NAVY     = '#1A2647';

const TYPE_DARK = '#0A0A0A'; // type baseline both options share — slightly warmer than pure

const candidates = [
  {
    name: 'Charcoal Gray',
    hex: CHARCOAL,
    note: 'Quieter, warm-neutral, sophisticated. Lets pink stay the star.',
  },
  {
    name: 'Navy Blue',
    hex: NAVY,
    note: "Editorial, classic pink-and-navy pairing. Bolder character — competes with pink for attention.",
  },
];
---

<BaseLayout title="Palette preview — pink + cream + deep">
  <article class="px-6 py-12 md:py-16" style={`background-color:${WHITE}; color:${TYPE_DARK};`}>
    <div class="mx-auto max-w-screen-2xl">
      <p class="meta" style="opacity:0.5;">Internal · palette preview · add a fourth colour</p>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Pink &middot; <span style={`background-color:${CLOUD}; padding:0 0.3em;`}>Cream</span> &middot; White &middot; <span style="opacity:0.5;">?</span>
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed md:text-xl" style="opacity:0.85;">
        The fourth colour does the quiet jobs: deep type, mood surfaces (instead of black bands), outline buttons, borders, dark sections that contrast pink without fighting it. Both candidates render below in the same compositions so you can compare like-for-like.
      </p>

      <div class="mt-12 grid gap-10 lg:grid-cols-2 lg:gap-8">
        {candidates.map((d) => (
          <section class="overflow-hidden rounded-3xl" style={`border:1px solid ${d.hex};`}>

            <!-- Swatch header -->
            <header class="flex items-center justify-between gap-6 px-8 py-6" style={`border-bottom:1px solid ${d.hex}; background-color:${WHITE};`}>
              <div>
                <p class="meta" style="opacity:0.5;">Option</p>
                <h2 class="mt-1 font-display text-2xl font-bold tracking-tight md:text-3xl">{d.name}</h2>
                <p class="meta mt-1" style="opacity:0.6;">{d.hex} · paired with pink #EB437F · cream #F1ECE0 · white</p>
              </div>
              <div class="flex gap-2">
                <span class="block h-12 w-12 rounded-full" style={`background-color:${PINK};`}></span>
                <span class="block h-12 w-12 rounded-full" style={`background-color:${CLOUD};`}></span>
                <span class="block h-12 w-12 rounded-full" style={`background-color:${d.hex};`}></span>
              </div>
            </header>

            <!-- 1. Cream hero with pink shape, deep type -->
            <div class="relative overflow-hidden px-8 py-12 md:px-10 md:py-16" style={`background-color:${CLOUD}; color:${d.hex};`}>
              <span class="absolute -right-24 -top-24 block h-72 w-72 rounded-full md:-right-16 md:-top-16 md:h-80 md:w-80" style={`background-color:${PINK};`} aria-hidden="true"></span>
              <div class="relative">
                <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>Adult ski camps</p>
                <h3 class="mt-3 font-display text-3xl font-bold leading-[0.95] tracking-tight md:text-5xl">
                  Five days on snow.<br/>One serious step up.
                </h3>
                <p class="mt-4 max-w-md text-base md:text-lg" style="opacity:0.8;">
                  Small-group camps for intermediate and advanced skiers.
                </p>
                <div class="mt-6 flex flex-wrap gap-3">
                  <a href="#" class="inline-flex items-center rounded-full px-5 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${PINK}; color:${WHITE};`}>Reserve your place</a>
                  <a href="#" class="inline-flex items-center rounded-full px-5 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:transparent; color:${d.hex}; border:1px solid ${d.hex};`}>See the camps</a>
                </div>
              </div>
            </div>

            <!-- 2. DEEP-SURFACE BAND — using the candidate as a mood surface -->
            <div class="px-8 py-12 md:px-10 md:py-16" style={`background-color:${d.hex}; color:${CLOUD};`}>
              <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>The numbers</p>
              <h3 class="mt-3 font-display text-2xl font-bold leading-tight tracking-tight md:text-4xl">
                Twenty thousand clients.<br/>
                Twenty-five instructors.
              </h3>
              <div class="mt-8 grid gap-3 sm:grid-cols-2">
                <div class="rounded-2xl p-5" style={`background-color:${WHITE}; color:${d.hex};`}>
                  <p class="meta" style="opacity:0.65;">Ratio</p>
                  <p class="mt-1 font-display text-2xl font-bold tracking-tight">8:1 max</p>
                </div>
                <div class="rounded-2xl p-5" style={`background-color:${CLOUD}; color:${d.hex};`}>
                  <p class="meta" style="opacity:0.65;">Length</p>
                  <p class="mt-1 font-display text-2xl font-bold tracking-tight">5 days</p>
                </div>
              </div>
            </div>

            <!-- 3. White section, deep type, pink badge -->
            <div class="px-8 py-12 md:px-10 md:py-16" style={`background-color:${WHITE}; color:${d.hex};`}>
              <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>Why students choose Peak</p>
              <h3 class="mt-3 font-display text-xl font-bold leading-tight tracking-tight md:text-3xl">
                Coached by the people who train other instructors.
              </h3>
              <p class="mt-4 max-w-md text-base" style="opacity:0.85;">
                The same coaches who run our
                <a href="#" class="px-1" style={`background-color:${PINK}; color:${WHITE}; text-decoration:none;`}>BASI courses</a>
                are coaching you. Read more about
                <a href="#" class="ml-1 underline-offset-4 underline" style={`color:${d.hex}; text-decoration-color:${PINK}; text-decoration-thickness:2px;`}>how we coach</a>.
              </p>

              <!-- Numbered badge -->
              <div class="mt-8 flex items-start gap-4">
                <span class="meta inline-flex h-14 w-14 items-center justify-center rounded-full" style={`background-color:${PINK}; color:${WHITE};`}>01</span>
                <div>
                  <h4 class="font-display text-lg font-bold tracking-tight md:text-xl">Eight building blocks</h4>
                  <p class="mt-1 max-w-xs text-sm" style="opacity:0.75;">The six essentials behind every good skier.</p>
                </div>
              </div>
            </div>

            <!-- 4. Card grid — outline cards in deep colour -->
            <div class="px-8 py-10 md:px-10 md:py-12" style={`background-color:${WHITE};`}>
              <p class="meta" style={`color:${d.hex}; opacity:0.65;`}>Outline cards in {d.name}</p>
              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                <div class="rounded-2xl p-5" style={`background-color:${WHITE}; color:${d.hex}; border:1px solid ${d.hex};`}>
                  <p class="meta" style="opacity:0.65;">Cream</p>
                  <p class="mt-1 font-display text-lg font-bold tracking-tight">Calm</p>
                </div>
                <div class="rounded-2xl p-5" style={`background-color:${CLOUD}; color:${d.hex}; border:1px solid ${d.hex};`}>
                  <p class="meta" style="opacity:0.65;">Pink</p>
                  <p class="mt-1 font-display text-lg font-bold tracking-tight">Bold</p>
                </div>
                <div class="rounded-2xl p-5" style={`background-color:${d.hex}; color:${CLOUD};`}>
                  <p class="meta" style="opacity:0.65;">Deep</p>
                  <p class="mt-1 font-display text-lg font-bold tracking-tight">Quiet</p>
                </div>
              </div>
            </div>

            <!-- Footnote -->
            <footer class="px-8 py-4" style={`border-top:1px solid ${d.hex}; background-color:${WHITE};`}>
              <p class="meta" style={`color:${d.hex}; opacity:0.7;`}>{d.note}</p>
            </footer>
          </section>
        ))}
      </div>

      <div class="mt-20 max-w-3xl pt-12" style={`border-top:1px solid ${TYPE_DARK};`}>
        <p class="meta" style="opacity:0.55;">What the fourth colour does</p>
        <h2 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">The quiet job</h2>
        <ul class="mt-6 space-y-3 text-base md:text-lg" style="opacity:0.85;">
          <li>· <strong>Type</strong> — body and headings sit on the deep colour instead of pure black. Subtly warmer (charcoal) or richer (navy).</li>
          <li>· <strong>Mood surfaces</strong> — full-section bands use this colour instead of the harsh black we tried earlier (e.g. the "numbers" band above).</li>
          <li>· <strong>Outline buttons + borders</strong> — secondary CTAs and card outlines use this in place of black.</li>
          <li>· <strong>Underlines on inline links</strong> — the link decoration colour.</li>
        </ul>
        <p class="mt-6 max-w-2xl text-base md:text-lg" style="opacity:0.7;">
          <strong>Charcoal</strong> lets pink stay the star. <strong>Navy</strong> adds a second strong character — more editorial, but with more visual competition. Pick the one that feels right for the Peak voice.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
