---
/**
 * Throwaway palette preview — Hot Pink + White + Cloud Dancer.
 *
 * Three surface tones: pure white (clean), Cloud Dancer cream (calm),
 * hot pink (loud). Cream is the buffer between white and pink so the
 * high-contrast moments have breathing room. Black is reserved for
 * type only — no longer used for surfaces or buttons.
 *
 * Delete this file once a palette decision is made.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const WHITE  = '#FFFFFF'; // bright clean surface
const CLOUD  = '#F1ECE0'; // Pantone 11-4201 Cloud Dancer — warm cream
const PINK   = '#EB437F'; // hot pink — accent + bold-section surface
const BLACK  = '#0A0A0A'; // type only

const palette = [
  { name: 'White',        hex: WHITE, role: 'Bright clean surface' },
  { name: 'Cloud Dancer', hex: CLOUD, role: 'Warm buffer · cards, alternating sections' },
  { name: 'Hot Pink',     hex: PINK,  role: 'Accent + bold-section surface' },
  { name: 'Black',        hex: BLACK, role: 'Type only — never on surfaces or buttons' },
];
---

<BaseLayout title="Palette preview — White · Cream · Pink">
  <article class="px-6 py-12 md:py-16" style={`background-color:${WHITE}; color:${BLACK};`}>
    <div class="mx-auto max-w-screen-2xl">
      <p class="meta" style="opacity:0.5;">Internal · palette preview · three surfaces, one accent</p>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        White. <span style={`background-color:${CLOUD}; padding:0 0.3em;`}>Cream.</span> <span style={`background-color:${PINK}; color:${WHITE}; padding:0 0.3em;`}>Pink.</span>
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed md:text-xl" style="opacity:0.85;">
        Three surfaces in rotation, plus black for type. Cream is the warm calm between bright white and bold pink — so when sections alternate (white → cream → pink → white), the eye gets breathing room before each loud moment. Black no longer does surface work; it's reserved for body type.
      </p>

      <!-- Swatches -->
      <ul class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {palette.map((c) => (
          <li class="rounded-2xl overflow-hidden" style={`background-color:${WHITE}; border:1px solid ${BLACK};`}>
            <div class="h-24" style={`background-color:${c.hex};`}></div>
            <div class="p-4">
              <p class="meta" style="opacity:0.55;">{c.name}</p>
              <p class="mt-1 font-display text-base font-bold tracking-tight">{c.hex}</p>
              <p class="meta mt-2" style="opacity:0.75;">{c.role}</p>
            </div>
          </li>
        ))}
      </ul>

      <!-- 1. HERO — cream surface, pink accent shape, black type, pink CTA -->
      <section class="mt-16 overflow-hidden rounded-3xl" style={`border:1px solid ${BLACK};`}>
        <div class="relative overflow-hidden px-8 py-16 md:px-12 md:py-24" style={`background-color:${CLOUD}; color:${BLACK};`}>
          <span class="absolute -right-32 -top-32 block h-96 w-96 rounded-full" style={`background-color:${PINK};`} aria-hidden="true"></span>

          <div class="relative">
            <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>Adult ski camps</p>
            <h2 class="mt-4 font-display text-4xl font-bold leading-[0.95] tracking-tight md:text-7xl">
              Five days on snow.<br/>
              One serious step up.
            </h2>
            <p class="mt-6 max-w-md text-base md:text-lg" style="opacity:0.85;">
              Small-group camps for intermediate and advanced skiers.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${PINK}; color:${WHITE};`}>Reserve your place</a>
              <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${WHITE}; color:${BLACK}; border:1px solid ${BLACK};`}>See the camps</a>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. ALTERNATING SURFACES — demonstrates the rhythm -->
      <section class="mt-16">
        <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>Pick your level</p>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight md:text-5xl">Where are you on the mountain?</h2>
        <p class="mt-4 max-w-2xl text-base md:text-lg" style="opacity:0.85;">
          Cards alternate between white, cream and pink. The mix gives the eye somewhere to rest between the bold pink moments.
        </p>

        <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <li class="rounded-2xl p-6" style={`background-color:${PINK}; color:${WHITE};`}>
            <p class="meta" style="opacity:0.85;">Level 01</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Beginner</h3>
            <p class="mt-2 text-sm" style="opacity:0.9;">Never skied before.</p>
          </li>
          <li class="rounded-2xl p-6" style={`background-color:${CLOUD}; color:${BLACK}; border:1px solid ${BLACK};`}>
            <p class="meta" style="opacity:0.6;">Level 02</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Improver</h3>
            <p class="mt-2 text-sm" style="opacity:0.85;">Snowplough on green.</p>
          </li>
          <li class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK}; border:1px solid ${BLACK};`}>
            <p class="meta" style="opacity:0.6;">Level 03</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Intermediate</h3>
            <p class="mt-2 text-sm" style="opacity:0.85;">Parallel on blues.</p>
          </li>
          <li class="rounded-2xl p-6" style={`background-color:${CLOUD}; color:${BLACK}; border:1px solid ${BLACK};`}>
            <p class="meta" style="opacity:0.6;">Level 04</p>
            <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">Advanced</h3>
            <p class="mt-2 text-sm" style="opacity:0.85;">Any colour run.</p>
          </li>
        </ul>
      </section>

      <!-- 3. PINK SURFACE BAND — full-section pink moment -->
      <section class="mt-16 overflow-hidden rounded-3xl p-10 md:p-16" style={`background-color:${PINK}; color:${WHITE};`}>
        <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${WHITE}; color:${PINK};`}>The numbers</p>
        <h2 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Twenty thousand clients.<br/>
          Twenty-five instructors.<br/>
          One school.
        </h2>

        <div class="mt-12 grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK};`}>
            <p class="meta" style="opacity:0.6;">Coaching ratio</p>
            <p class="mt-2 font-display text-3xl font-bold tracking-tight">8:1 max</p>
          </div>
          <div class="rounded-2xl p-6" style={`background-color:${CLOUD}; color:${BLACK};`}>
            <p class="meta" style="opacity:0.6;">Length</p>
            <p class="mt-2 font-display text-3xl font-bold tracking-tight">5 days</p>
          </div>
          <div class="rounded-2xl p-6" style={`background-color:${WHITE}; color:${BLACK};`}>
            <p class="meta" style="opacity:0.6;">Qualification</p>
            <p class="mt-2 font-display text-3xl font-bold tracking-tight">BASI Trainers</p>
          </div>
        </div>
      </section>

      <!-- 4. CREAM SECTION — body with pink kicker + soft pink badge -->
      <section class="mt-16 overflow-hidden rounded-3xl p-10 md:p-16" style={`background-color:${CLOUD}; color:${BLACK};`}>
        <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>Why students choose Peak</p>
        <h2 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Coached by the people who train other instructors.
        </h2>
        <p class="mt-6 max-w-2xl text-base leading-relaxed md:text-lg" style="opacity:0.85;">
          You learn faster because we never lose track of you. The same coaches who run our
          <a href="#" class="px-1" style={`background-color:${PINK}; color:${WHITE}; text-decoration:none;`}>BASI courses</a>
          are coaching you. Eight skiers max.
        </p>

        <!-- Numbered badges all pink -->
        <ol class="mt-10 space-y-8">
          {[
            { n: '01', t: 'Eight building blocks' },
            { n: '02', t: 'Ski-fit' },
            { n: '03', t: 'Performance analysis' },
          ].map((row) => (
            <li class="flex items-start gap-5">
              <span class="meta inline-flex h-14 w-14 items-center justify-center rounded-full" style={`background-color:${PINK}; color:${WHITE};`}>{row.n}</span>
              <div>
                <h4 class="font-display text-xl font-bold tracking-tight md:text-2xl">{row.t}</h4>
                <p class="mt-2 max-w-md text-base" style="opacity:0.8;">A line of supporting copy that explains the thing.</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- 5. WHITE SECTION — bright clean moment with pink CTA -->
      <section class="mt-16 px-2 md:px-0">
        <p class="inline-block px-2 py-1 text-xs uppercase tracking-widest" style={`font-family:'Courier New',Courier,monospace; background-color:${PINK}; color:${WHITE};`}>Ready to book</p>
        <h2 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Pick a camp. Hold your place.
        </h2>
        <p class="mt-4 max-w-md text-base md:text-lg" style="opacity:0.85;">
          Live availability. Refundable deposit. We confirm 6 weeks ahead.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${PINK}; color:${WHITE};`}>Check availability →</a>
          <a href="#" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-wider no-underline" style={`background-color:${WHITE}; color:${BLACK}; border:1px solid ${BLACK};`}>Talk to us first</a>
        </div>
      </section>

      <!-- Notes -->
      <div class="mt-20 max-w-3xl pt-12" style={`border-top:1px solid ${BLACK};`}>
        <p class="meta" style="opacity:0.55;">How the three surfaces alternate</p>
        <h2 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">Rhythm, not just contrast</h2>
        <ul class="mt-6 space-y-3 text-base md:text-lg" style="opacity:0.85;">
          <li>· <strong>White</strong> — the default body surface. Clean, bright. Where most reading happens.</li>
          <li>· <strong style={`background-color:${CLOUD}; padding:0 0.3em;`}>Cloud Dancer</strong> — used for sections that need a calm pause: side cards, alternating bands, body sections that aren't loud. The warm buffer.</li>
          <li>· <strong style={`background-color:${PINK}; color:${WHITE}; padding:0 0.3em;`}>Hot Pink</strong> — bold moments only. CTAs, hero highlights, full-section "look here" panels (like the numbers band). Used sparingly so it lands.</li>
          <li>· <strong>Black</strong> — type only. Never a surface, never a button. The discipline that prevents the page going harsh.</li>
        </ul>
        <p class="mt-6 max-w-2xl text-base md:text-lg" style="opacity:0.7;">
          Scroll the preview top-to-bottom. You'll feel the page exhale on the cream/white sections, then notice the pink ones. That cadence is the point.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
