---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';
import Section from '../../components/ui/Section.astro';
import InstructorCard from '../../components/instructors/InstructorCard.astro';
import heroImage from '../../assets/images/hero-instructors.jpg';

const allInstructors = await getCollection('instructors', ({ data }) => !data.draft);
const instructors = allInstructors.sort((a, b) =>
  a.data.name.split(' ')[0].localeCompare(b.data.name.split(' ')[0])
);

const joinFormUrl = 'https://forms.gle/MU1wVdNeRmoAK6AW8';

// Unique values for the filter chips.
const resorts = [...new Set(instructors.flatMap((i) => i.data.resorts))].sort();
const languages = [...new Set(instructors.flatMap((i) => i.data.languages))].sort();
---

<BaseLayout title="Instructors · Peak Snowsports">
  <Hero
    kicker="The team"
    headline="No anonymous ESF badges."
    sub="Every Peak instructor is BASI-qualified and holds a full French Carte Pro. Browse, or let us match you."
    variant="compact"
    image={heroImage}
    imageAlt="Skiers and instructors spread across a piste in long afternoon shadow."
  />

  <Section kicker="Find your instructor" title="Filter the team.">
    <div class="grid gap-4 md:grid-cols-3">
      <label class="block">
        <span class="meta text-olive/60">Resort</span>
        <select class="mt-2 w-full border-b border-olive/30 bg-transparent py-3 focus:border-yellow focus:outline-none">
          <option>All</option>
          {resorts.map((r) => <option>{r}</option>)}
        </select>
      </label>
      <label class="block">
        <span class="meta text-olive/60">Speciality</span>
        <select class="mt-2 w-full border-b border-olive/30 bg-transparent py-3 focus:border-yellow focus:outline-none">
          <option>All</option>
          <option>Private</option>
          <option>Group</option>
          <option>Family</option>
          <option>Off-piste</option>
          <option>Race</option>
        </select>
      </label>
      <label class="block">
        <span class="meta text-olive/60">Language</span>
        <select class="mt-2 w-full border-b border-olive/30 bg-transparent py-3 focus:border-yellow focus:outline-none">
          <option>All</option>
          {languages.map((l) => <option>{l}</option>)}
        </select>
      </label>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-8 md:grid-cols-3 lg:grid-cols-4">
      {instructors.map((i) => (
        <InstructorCard
          name={i.data.name}
          role={i.data.role}
          resort={i.data.resorts[0]}
          photo={i.data.photo}
          href={`/instructors/${i.id}`}
        />
      ))}

      <a href={joinFormUrl} target="_blank" rel="noopener" class="group block no-underline">
        <div class="flex aspect-[3/4] w-full flex-col justify-between overflow-hidden rounded-2xl bg-olive-deep p-6 text-salt">
          <p class="meta-pill">We're hiring</p>
          <div>
            <h3 class="font-display text-3xl font-bold leading-[1.0] tracking-tight">Join the team</h3>
            <span class="mt-5 inline-flex items-center rounded-full bg-yellow px-5 py-2.5 font-display text-sm font-bold uppercase tracking-tight text-olive-deep transition group-hover:bg-salt">
              Apply now →
            </span>
          </div>
        </div>
        <div class="mt-4">
          <p class="meta text-olive/50">All resorts</p>
          <h3 class="mt-1 text-lg font-semibold leading-tight group-hover:underline">Become an instructor</h3>
          <p class="mt-1 text-sm text-olive/60">Full or part season</p>
        </div>
      </a>
    </div>

    {instructors.length === 0 && (
      <p class="mt-16 text-olive/60">No instructors yet.</p>
    )}
  </Section>
</BaseLayout>
