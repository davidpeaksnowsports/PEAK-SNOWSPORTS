---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';

export async function getStaticPaths() {
  const instructors = await getCollection('instructors', ({ data }) => !data.draft);
  return instructors.map((instructor) => ({
    params: { slug: instructor.id },
    props: { instructor },
  }));
}

const { instructor } = Astro.props;
const { Content } = await render(instructor);
const d = instructor.data;
---

<BaseLayout title={`${d.name}, Peak Snowsports`}>
  <article class="px-6 pb-24 pt-16 md:pb-32 md:pt-24">
    <div class="mx-auto max-w-screen-2xl">
      <p class="meta text-olive/40">
        <a href="/instructors" class="-mx-1 rounded px-1 no-underline transition-colors hover:bg-yellow">Instructors</a>
        <span class="px-2">/</span>
        <span>{d.name}</span>
      </p>

      <div class="mt-10 grid gap-12 md:grid-cols-12">
        <div class="md:col-span-5">
          <div class="aspect-[3/4] overflow-hidden rounded-3xl bg-brown">
            {d.photo ? (
              <img src={d.photo} alt={d.name} class="h-full w-full object-cover" />
            ) : (
              <div class="flex h-full w-full items-center justify-center">
                <span class="meta text-salt/30">portrait pending</span>
              </div>
            )}
          </div>
        </div>

        <div class="md:col-span-7">
          <p class="meta-pill">{d.resorts.join(' · ')} · Instructor</p>
          <h1 class="mt-4 text-5xl leading-tight md:text-7xl">{d.name}</h1>
          {d.role && <p class="mt-3 text-lg text-olive/70">{d.role}</p>}

          <div class="mt-10 space-y-4 text-lg leading-relaxed text-olive/80">
            <Content />
          </div>

          <dl class="mt-12 grid grid-cols-2 gap-x-8 gap-y-6 border-t border-olive/10 pt-12 text-sm">
            {d.qualifications.length > 0 && (
              <div class="col-span-2">
                <dt class="meta text-olive/50">Qualifications</dt>
                <dd class="mt-2 space-y-1">
                  {d.qualifications.map((q) => <div>{q}</div>)}
                </dd>
              </div>
            )}
            {d.languages.length > 0 && (
              <div>
                <dt class="meta text-olive/50">Languages</dt>
                <dd class="mt-2">{d.languages.join(' · ')}</dd>
              </div>
            )}
            {d.specialities.length > 0 && (
              <div>
                <dt class="meta text-olive/50">Specialities</dt>
                <dd class="mt-2">{d.specialities.join(' · ')}</dd>
              </div>
            )}
            {d.resorts.length > 0 && (
              <div>
                <dt class="meta text-olive/50">{d.resorts.length === 1 ? 'Resort' : 'Resorts'}</dt>
                <dd class="mt-2">{d.resorts.join(' · ')}</dd>
              </div>
            )}
            {d.likes && (
              <div>
                <dt class="meta text-olive/50">Three likes</dt>
                <dd class="mt-2">{d.likes}</dd>
              </div>
            )}
            {d.dislikes && (
              <div>
                <dt class="meta text-olive/50">Three dislikes</dt>
                <dd class="mt-2">{d.dislikes}</dd>
              </div>
            )}
            {d.favouriteKit && (
              <div class="col-span-2">
                <dt class="meta text-olive/50">Favourite bit of ski kit</dt>
                <dd class="mt-2">{d.favouriteKit}</dd>
              </div>
            )}
            {d.topTip && (
              <div class="col-span-2 border-l border-yellow pl-6">
                <dt class="meta text-olive/50">Top tip</dt>
                <dd class="mt-2 font-display text-xl font-bold leading-snug text-olive">{d.topTip}</dd>
              </div>
            )}
          </dl>

          <div class="mt-12">
            <a
              href="/book"
              class="inline-flex rounded-full bg-yellow px-6 py-3 font-display text-sm font-bold uppercase tracking-tight text-olive-deep no-underline transition hover:bg-salt"
            >
              Request {d.name.split(' ')[0]} →
            </a>
            <p class="meta mt-4 text-olive/40">Deep-links into the Arch preferred-instructor flow.</p>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
