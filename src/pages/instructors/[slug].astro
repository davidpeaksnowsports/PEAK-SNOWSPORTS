---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import { LOREM, LOREM_LONG } from '../../lib/utils';

export function getStaticPaths() {
  return Array.from({ length: 12 }, (_, i) => ({
    params: { slug: `instructor-${i + 1}` },
    props: { index: i + 1 },
  }));
}

const { slug } = Astro.params;
const { index } = Astro.props;

const resort = ['Morzine', 'Chatel', 'Les Gets'][(index - 1) % 3];
---

<BaseLayout title={`Instructor ${index} — Peak Snowsports`}>
  <article class="px-6 pb-24 pt-16 md:pb-32 md:pt-24">
    <div class="mx-auto grid max-w-screen-2xl gap-16 md:grid-cols-12">
      <div class="md:col-span-5">
        <div class="aspect-[3/4] bg-brown" aria-hidden="true" />
      </div>

      <div class="md:col-span-7">
        <p class="meta text-yellow">{resort} · Instructor</p>
        <h1 class="mt-4 text-5xl font-semibold leading-tight md:text-7xl">Instructor {index}</h1>

        <div class="mt-8 space-y-4 text-lg leading-relaxed text-salt/80">
          <p>{LOREM_LONG}</p>
          <p>{LOREM}</p>
        </div>

        <dl class="mt-12 grid grid-cols-2 gap-x-8 gap-y-6 border-t border-salt/10 pt-12 text-sm">
          <div>
            <dt class="meta text-salt/50">Qualifications</dt>
            <dd class="mt-2">Lorem ipsum · Dolor sit · Amet</dd>
          </div>
          <div>
            <dt class="meta text-salt/50">Languages</dt>
            <dd class="mt-2">EN · FR</dd>
          </div>
          <div>
            <dt class="meta text-salt/50">Specialities</dt>
            <dd class="mt-2">Private · Off-piste</dd>
          </div>
          <div>
            <dt class="meta text-salt/50">Resort</dt>
            <dd class="mt-2">{resort}</dd>
          </div>
        </dl>

        <div class="mt-12">
          <a href="/book" class="inline-flex bg-yellow px-6 py-3 text-sm font-semibold uppercase tracking-wider text-navy-deep no-underline hover:bg-salt">
            Request this instructor
          </a>
          <p class="meta mt-4 text-salt/40">Deep-links into the Arch preferred-instructor flow.</p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
