---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';
import Section from '../../components/ui/Section.astro';
import heroImage from '../../assets/images/hero-about.jpg';

const all = await getCollection('accommodation', ({ data }) => !data.draft);
const providers = all.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<BaseLayout title="Accommodation — Peak Snowsports" description="Hand-picked accommodation partners we trust. One enquiry, the right team in touch.">
  <Hero
    kicker="Accommodation"
    headline="Accommodation you can trust."
    sub="A hand-picked list of operators we work with. Tell us where, when, and what kind of place. We pass the brief to the right partner — and stay on hand if anything needs sorting."
    primaryCta={{ href: '#enquire', label: 'Make an enquiry' }}
    secondaryCta={{ href: '#partners', label: 'Browse partners' }}
    variant="compact"
    image={heroImage}
    imageAlt="A snow-laden Alpine ridge in the Portes du Soleil."
  />

  <!-- How it works -->
  <Section kicker="How it works" title="One enquiry. The right team in touch.">
    <ol class="grid gap-6 md:grid-cols-3">
      <li class="rounded-3xl border border-olive bg-snow p-8">
        <span class="meta text-olive/40">01</span>
        <h3 class="mt-3 font-display text-2xl font-bold tracking-tight">Tell us what you want</h3>
        <p class="mt-4 text-base leading-relaxed text-olive/75">Dates, party size, kind of place. Pick a preferred partner if you've already had a look, or leave it open and we'll match you.</p>
      </li>
      <li class="rounded-3xl border border-olive bg-snow p-8">
        <span class="meta text-olive/40">02</span>
        <h3 class="mt-3 font-display text-2xl font-bold tracking-tight">We pass the brief on</h3>
        <p class="mt-4 text-base leading-relaxed text-olive/75">Your request goes straight to the partner. We keep a copy so we can chase it through and make sure nothing falls between teams.</p>
      </li>
      <li class="rounded-3xl border border-olive bg-snow p-8">
        <span class="meta text-olive/40">03</span>
        <h3 class="mt-3 font-display text-2xl font-bold tracking-tight">They sort you out</h3>
        <p class="mt-4 text-base leading-relaxed text-olive/75">Availability and options come back from the partner directly. You book with them. We're around the whole time if you need us.</p>
      </li>
    </ol>
  </Section>

  <!-- Provider cards -->
  <Section id="partners" kicker="Our partners" title="Five trusted operators.">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {providers.map((p) => (
        <a href={`/accommodation/${p.id}`} class="group block no-underline">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-2xl bg-brown">
            {p.data.photo ? (
              <img
                src={p.data.photo}
                alt={p.data.name}
                loading="lazy"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center">
                <span class="meta text-salt/30">image pending</span>
              </div>
            )}
          </div>
          <div class="mt-5">
            {p.data.style && (
              <span class="meta inline-flex items-center rounded-full bg-yellow px-3 py-1 text-olive-deep">{p.data.style}</span>
            )}
            <h3 class="mt-3 font-display text-2xl font-bold tracking-tight transition-colors group-hover:bg-yellow md:text-3xl">{p.data.name}</h3>
            <p class="mt-3 text-base leading-relaxed text-olive/75">{p.data.tagline}</p>
            <p class="meta mt-4 text-olive/50">{p.data.locations.join(' · ')}</p>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <!-- Enquiry form -->
  <section id="enquire" class="bg-olive-deep text-salt">
    <div class="mx-auto max-w-screen-2xl px-6 py-20 md:py-24">
      <p class="meta-pill">Make an enquiry</p>
      <h2 class="mt-6 max-w-3xl text-4xl leading-tight md:text-6xl">Tell us what you're looking for.</h2>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-salt/80">
        One form, one click. We pass your brief to the partner and keep a copy so nothing slips. They'll be in touch with availability and prices direct.
      </p>

      <form action="https://formspree.io/f/REPLACE_WITH_FORM_ID" method="POST" class="mt-12 grid max-w-3xl gap-6">
        <input type="hidden" name="_subject" value="Accommodation enquiry from peaksnowsports.com" />

        <div class="grid gap-6 md:grid-cols-2">
          <label class="block">
            <span class="meta text-salt/60">Name *</span>
            <input type="text" name="name" required class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none" />
          </label>
          <label class="block">
            <span class="meta text-salt/60">Email *</span>
            <input type="email" name="email" required class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none" />
          </label>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <label class="block">
            <span class="meta text-salt/60">Arrival date</span>
            <input type="date" name="arrival" class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none [color-scheme:dark]" />
          </label>
          <label class="block">
            <span class="meta text-salt/60">Departure date</span>
            <input type="date" name="departure" class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none [color-scheme:dark]" />
          </label>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <label class="block">
            <span class="meta text-salt/60">Party size</span>
            <input type="number" min="1" name="party_size" class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none" />
          </label>
          <label class="block">
            <span class="meta text-salt/60">Preferred partner</span>
            <select name="provider" class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none [&>option]:bg-olive-deep">
              <option value="">No preference — match me</option>
              {providers.map((p) => (
                <option value={p.data.name}>{p.data.name}</option>
              ))}
            </select>
          </label>
        </div>

        <label class="block">
          <span class="meta text-salt/60">Anything else?</span>
          <textarea name="message" rows="4" class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 text-salt focus:border-yellow focus:outline-none"></textarea>
        </label>

        <button type="submit" class="justify-self-start rounded-full bg-yellow px-8 py-4 font-display text-base font-bold uppercase tracking-tight text-olive-deep transition hover:bg-salt">
          Send enquiry →
        </button>

        <p class="meta text-salt/85">
          Your enquiry routes to the chosen partner and a copy comes to us for tracking. We'll never share your details beyond that.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>
