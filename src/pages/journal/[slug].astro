---
import { getCollection, render } from 'astro:content';
import JournalLayout from '../../layouts/JournalLayout.astro';
import Section from '../../components/ui/Section.astro';
import PostCard from '../../components/journal/PostCard.astro';
import { formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const moreFromAuthor = allPosts
  .filter((p) => p.data.author === post.data.author && p.id !== post.id)
  .slice(0, 3);
---

<JournalLayout
  title={post.data.title}
  description={post.data.seoDescription ?? post.data.excerpt}
  category={post.data.category}
  author={post.data.author}
  date={formatDate(post.data.publishedAt)}
  hero={post.data.hero}
  heroAlt={post.data.title}
>
  <Content />
</JournalLayout>

{moreFromAuthor.length > 0 && (
  <Section kicker={`More from ${post.data.author}`} title="Keep reading.">
    <div class="grid gap-12 md:grid-cols-3">
      {moreFromAuthor.map((p) => (
        <PostCard
          title={p.data.title}
          category={p.data.category}
          author={p.data.author}
          date={formatDate(p.data.publishedAt)}
          href={`/journal/${p.id}`}
        />
      ))}
    </div>
  </Section>
)}
