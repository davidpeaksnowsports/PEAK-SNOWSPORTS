---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';
import Section from '../../components/ui/Section.astro';
import BookingWidget from '../../components/booking/BookingWidget.astro';

const programmes = [
  {
    name: 'Avoriaz Kids Race Camps',
    audience: 'Aspiring racers, ages 8 to 18',
    body:
      'Lindarets-based race coaching for the junior ranks. Mix of race training and all-mountain skiing for well-rounded development. Slalom and giant slalom, technique, line and tactics inside and outside the gates.',
    facts: [
      { label: 'Meeting point', value: 'Salle Hors Sac, top of Ardent Bubble' },
      { label: 'Schedule', value: '09:00 start, pick-up 15:00' },
    ],
  },
  {
    name: 'Austria Race Camp · Kids',
    audience: 'Kids racers, October',
    body:
      'A week of high-intensity, skill-boosting race training in the Austrian Alps. Inlier (chaperoned travel from London, accommodation, meals, lift passes) or Outlier (coaching only) options. World-class glacier training for pre-season prep.',
    facts: [
      { label: 'Location', value: 'Hintertux, Austria' },
      { label: 'Dates', value: 'Released for 2026/27 season' },
      { label: 'Coaching', value: '6 full days' },
    ],
  },
  {
    name: 'Austria Race Camp · Adults',
    audience: 'Adult racers, October',
    body:
      'Five days of slalom, GS and technical free skiing in Austria. Video analysis included. Aimed at FIS, Masters Racing, EUROTEST and ISIA speed-test training. Open to those who have skied gates previously.',
    facts: [
      { label: 'Location', value: 'Hintertux, Austria' },
      { label: 'Dates', value: 'Released for 2026/27 season' },
      { label: 'Coaching', value: '5 full days + video' },
    ],
  },
  {
    name: 'FIS / Eurotest / Masters · Châtel',
    audience: 'Serious racers, 16+',
    body:
      'A five-day intensive in Châtel refining slalom and giant slalom with expert coaching. Half-day sessions Monday to Friday. Drop-in option available, train when it suits you. Email chatel@peaksnowsports.com to arrange.',
    facts: [
      { label: 'Location', value: 'Châtel' },
      { label: 'Format', value: 'Half-day sessions, Mon, Fri' },
      { label: 'Drop-in', value: 'Available' },
    ],
  },
];

// Four race-specific levels from the source page.
const levels = [
  {
    name: 'New to racing',
    bullets: [
      'Completed all ski school levels on snow',
      'Level 9 Snowlife award',
      'ESF Gold Star',
    ],
  },
  {
    name: 'Actively racing on dry slope',
    bullets: [
      'Attending local or national competitions',
      'Dry-slope ski racing / part of a club',
    ],
  },
  {
    name: 'Competing on snow',
    bullets: [
      'Attending on-snow races',
      'Competing in the English/Welsh Champs or equivalent',
    ],
  },
  {
    name: 'Seasoned pro',
    bullets: [
      'Competing in on-snow races',
      'British Championship level or equivalent',
    ],
  },
];

const faqs = [
  {
    q: 'Who is race coaching for?',
    a: 'Anyone seriously interested in race technique. From kids who have completed ski school and want to step into gates, through to FIS, Masters and Eurotest candidates.',
  },
  {
    q: 'Do I need my own race kit?',
    a: 'Slalom-stiff skis and a helmet with chin guard for slalom sessions; GS skis and a hard-shell helmet for GS. We can sort hire with our partners, email us before you arrive.',
  },
  {
    q: 'What if my child is between levels?',
    a: "We usually run multiple groups so we can move racers around to the right level on day one. If we can't, we offer the equivalent in private coaching.",
  },
  {
    q: 'Insurance?',
    a: 'You arrange your own. Winter sports cover is essential and must include racing if you race in gates. We carry public liability cover up to £10m.',
  },
  {
    q: 'What if the weather turns?',
    a: 'We run lessons in all weather. If the lifts are officially closed, we send a statement of fact you can take to your insurer.',
  },
  {
    q: 'Cancellation?',
    a: "Give us a month's notice and you're 100% refunded. Inside a month, we issue race-coaching credit.",
  },
];
---

<BaseLayout
  title="Race coaching · Peak Snowsports"
  description="Slalom and GS race coaching for kids and adults. Avoriaz weekly camps, Austria pre-season camps, Châtel FIS / Eurotest / Masters training."
>
  <Hero
    kicker="Lessons · Race coaching"
    headline="Gates. Times. Repeat."
    sub="Outlier camps for superstar racers pushing through the junior ranks. Plus pre-season camps in Austria and FIS / Eurotest / Masters training in Châtel."
    primaryCta={{ href: '#availability', label: 'Check availability' }}
    secondaryCta={{ href: '#programmes', label: 'See the programmes' }}
    variant="full"
    video="/videos/carving.mp4"
    videoPoster="/videos/carving-poster.jpg"
    imageAlt="A racer carving down a piste."
  />

  <!-- Welcome -->
  <Section kicker="Welcome" title="Four programmes. One coaching team.">
    <div class="grid items-start gap-12 lg:grid-cols-[1fr_minmax(0,420px)] lg:gap-20">
      <div class="space-y-6 text-lg leading-relaxed text-olive/85 md:text-xl">
        <p>
          Expert race coaching in slalom and GS, with a focus on technique, line and tactics inside and outside the gates. From kids stepping out of ski school for the first time, through to seasoned racers preparing for FIS or Eurotest.
        </p>
        <p>
          Train with the same coaches who run our performance courses and instructor exams.
        </p>
      </div>
      <ul class="grid grid-cols-2 gap-3">
        <li class="rounded-2xl border border-olive bg-cream px-5 py-4">
          <p class="meta text-olive/55">Disciplines</p>
          <p class="mt-2 font-display text-xl font-bold tracking-tight">SL / GS</p>
        </li>
        <li class="rounded-2xl border border-olive bg-cream px-5 py-4">
          <p class="meta text-olive/55">Ages</p>
          <p class="mt-2 font-display text-xl font-bold tracking-tight">8+ to FIS</p>
        </li>
        <li class="col-span-2 rounded-2xl border border-olive bg-cream px-5 py-4">
          <p class="meta text-olive/55">Where</p>
          <p class="mt-2 font-display text-xl font-bold tracking-tight">Avoriaz · Châtel · Hintertux</p>
        </li>
      </ul>
    </div>
  </Section>

  <!-- Programmes -->
  <Section id="programmes" kicker="The programmes" title="Pick your race camp.">
    <ul class="grid gap-6 md:grid-cols-2">
      {programmes.map((p) => (
        <li class="rounded-3xl border border-olive bg-snow p-8 md:p-10">
          <p class="meta text-olive/55">{p.audience}</p>
          <h3 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">{p.name}</h3>
          <p class="mt-4 text-base leading-relaxed text-olive/85 md:text-lg">{p.body}</p>
          <dl class="mt-6 grid gap-3 sm:grid-cols-2">
            {p.facts.map((f) => (
              <div class="rounded-xl bg-cream p-3">
                <dt class="meta text-olive/55">{f.label}</dt>
                <dd class="mt-1 text-sm font-semibold text-olive">{f.value}</dd>
              </div>
            ))}
          </dl>
          <a
            href="#availability"
            class="meta mt-6 inline-flex items-center gap-2 text-olive transition-colors hover:bg-pink hover:text-snow"
          >
            Check availability →
          </a>
        </li>
      ))}
    </ul>
  </Section>

  <!-- Find your level -->
  <Section kicker="Find your level" title="Where are you on the race ladder?">
    <p class="max-w-3xl text-lg leading-relaxed text-olive/80 md:text-xl">
      Read down until something sounds like you (or your kid). If you're between two, pick the lower, we move racers up on day one when it's a clear fit.
    </p>
    <ol class="mt-16 space-y-12">
      {levels.map((l, i) => (
        <li class="border-t border-olive/15 pt-10">
          <div class="grid gap-6 md:grid-cols-[5rem_1fr]">
            <span class="meta inline-flex h-14 w-14 items-center justify-center rounded-full bg-pink text-snow">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="font-display text-2xl font-bold tracking-tight md:text-3xl">{l.name}</h3>
              <ul class="mt-4 space-y-2">
                {l.bullets.map((b) => (
                  <li class="flex gap-3 text-base leading-relaxed text-olive/85 md:text-lg">
                    <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-pink" />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <!-- Availability -->
  <Section id="availability" kicker="Availability" title="Book race coaching.">
    <BookingWidget productId="race-coaching" variant="product" />
    <p class="meta mt-6 text-olive/60">
      Châtel-based programmes: email <a href="mailto:chatel@peaksnowsports.com" class="underline-offset-4 hover:bg-pink hover:text-snow hover:underline">chatel@peaksnowsports.com</a> to arrange.
    </p>
  </Section>

  <!-- FAQs -->
  <Section kicker="FAQs" title="The usual questions.">
    <div class="max-w-3xl">
      <dl class="divide-y divide-olive/15 border-y border-olive/15">
        {faqs.map((f) => (
          <div class="py-6">
            <dt class="font-display text-xl font-bold tracking-tight md:text-2xl">{f.q}</dt>
            <dd class="mt-3 text-base leading-relaxed text-olive/85 md:text-lg">{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </Section>
</BaseLayout>
