---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/booking/BookingWidget.astro';

const skills = [
  { title: 'Skiing foundations', body: 'Posture, movement, balance — the building blocks that everything else stacks on top of.' },
  { title: 'Turning', body: 'Getting real performance from the skis. Short and long GS carve turns.' },
  { title: 'Speed control', body: "Manage your speed where it matters. Find it where it doesn't." },
  { title: 'Mountain navigation', body: 'Reading the resort, planning runs, on-piste and off.' },
  { title: 'Safety & avalanche training', body: 'Essential mountain rules, rescue skills, avalanche protocol. Equipment provided for off-piste sessions.' },
  { title: 'Freestyle fun', body: 'Learn to see the whole mountain as a freestyle park. Halfpipes, jumps, boxes, all of it.' },
];

const prerequisites = [
  '7+ years old',
  'Confident on red runs, parallel turns',
  'Can carry own equipment',
  'Helmet compulsory',
  'Full area lift pass required',
];

const faqs = [
  {
    q: 'What level of skiing is required?',
    a: 'Confident on red runs, parallel turns, and able to carry own equipment. This keeps the group moving and lets every kid join every activity safely.',
  },
  {
    q: 'What age range is the club for?',
    a: 'Seven years and up. We want kids who are ready to engage with a season-long progression, not just turn up.',
  },
  {
    q: 'Can my child join partway through the season?',
    a: 'Yes — but call us first on +44 1483 616 522 so we can place them in the right group and make sure they integrate smoothly.',
  },
  {
    q: 'How many kids in each group?',
    a: 'Six to eight per coach. Small enough that every kid gets real attention every session.',
  },
  {
    q: 'What if the weather is bad?',
    a: "Safety comes first. If conditions make skiing unsafe, we postpone or cancel and tell parents as early as possible. Weather cancellations are refundable or rescheduled."
  },
  {
    q: 'Is lunch or snacks provided?',
    a: 'No — please pack snacks and water. Three-hour sessions are physically demanding and kids need to refuel.',
  },
  {
    q: 'What equipment is required?',
    a: "Own skis, poles, boots, helmet (compulsory) and ski clothing. We provide avalanche kit for the off-piste training sessions — we'll let you know in advance which sessions need it.",
  },
  {
    q: "What's the cancellation policy?",
    a: 'If your child can\'t attend, let us know in advance. Refunds and rescheduling are typically offered only for sessions cancelled due to weather or other unavoidable circumstances.',
  },
  {
    q: 'What safety measures are in place?',
    a: "All our coaches are trained in first aid, avalanche safety, and mountain rescue. Every kid gets coaching on slope rules and what to do in an emergency.",
  },
];
---

<BaseLayout title="Local Kids Club — Peak Snowsports">
  <!-- Breadcrumb + Hero -->
  <section id="top" class="bg-olive-deep text-salt">
    <div class="mx-auto max-w-screen-2xl px-6 pt-10 md:pt-12">
      <p class="meta text-salt/40">
        <a href="/lessons" class="no-underline hover:text-yellow">Lessons</a>
        <span class="px-2">/</span>
        <span>Local Kids Club</span>
      </p>
    </div>

    <div class="mx-auto max-w-screen-2xl px-6 pb-20 pt-10 md:pb-24 md:pt-14">
      <p class="meta text-yellow">Local Kids Club · 7+</p>
      <h1 class="mt-6 max-w-3xl text-5xl md:text-7xl">
        A whole season.<br />A whole skill set.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-salt/80 md:text-xl">
        Wednesday and Saturday afternoons through the off-peak weeks. Three-hour sessions. Thirty across the season. Coached by inspirational instructors who'll take your kid from confident parallel turner to all-mountain skier.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <span class="meta inline-flex items-center rounded-full border border-salt/20 px-4 py-2">3-hour sessions</span>
        <span class="meta inline-flex items-center rounded-full border border-salt/20 px-4 py-2">30 sessions across the season</span>
        <span class="meta inline-flex items-center rounded-full border border-salt/20 px-4 py-2">Min. 10 sessions recommended</span>
        <span class="meta inline-flex items-center rounded-full border border-salt/20 px-4 py-2">6–8 per coach</span>
      </div>
    </div>
  </section>

  <!-- Two-column: details + sticky widget -->
  <section class="px-6 py-20 md:py-24">
    <div class="mx-auto grid max-w-screen-2xl gap-12 lg:grid-cols-[1fr_400px] lg:gap-16">

      <!-- LEFT: details -->
      <div class="space-y-14">

        <div>
          <h2 class="text-3xl md:text-4xl">What you get</h2>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed text-olive/80">
            A holistic ski programme for local kids, led by coaches who actually want to teach. Each session is packed with progression — and the whole-season format means we get to build proper skills over time, not just give a quick lesson and send them off.
          </p>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-olive/80">
            Kids earn <strong class="font-semibold text-olive">PEAK levels</strong> and sustainably-made medals as they progress. Built on empathy, teamwork, and healthy competition.
          </p>
        </div>

        <div>
          <h2 class="text-3xl md:text-4xl">What we cover</h2>
          <div class="mt-8 grid gap-5 sm:grid-cols-2">
            {skills.map((s) => (
              <div class="rounded-2xl border border-olive/15 bg-snow p-6">
                <p class="meta text-olive/50">{s.title}</p>
                <p class="mt-3 text-base leading-relaxed text-olive/80">{s.body}</p>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-3xl md:text-4xl">Who it's for</h2>
          <div class="mt-6 flex flex-wrap gap-2">
            {prerequisites.map((p) => (
              <span class="meta rounded-full border border-olive/20 px-4 py-2 text-olive/70">{p}</span>
            ))}
          </div>
          <p class="mt-6 max-w-2xl text-base leading-relaxed text-olive/75">
            Joining partway through the season? Call us first on <a href="tel:+441483616522" class="underline-offset-4 hover:text-yellow hover:underline">+44 1483 616 522</a> so we can place your kid in the right group.
          </p>
        </div>

        <div>
          <h2 class="text-3xl md:text-4xl">FAQs</h2>
          <ul class="mt-8 divide-y divide-olive/10 border-y border-olive/10">
            {faqs.map((f) => (
              <li>
                <details class="group">
                  <summary class="flex cursor-pointer items-baseline gap-6 list-none py-5 [&::-webkit-details-marker]:hidden">
                    <span class="font-display text-lg font-bold tracking-tight md:text-xl">{f.q}</span>
                    <span class="ml-auto font-display text-xl text-olive/40 transition group-open:rotate-45">+</span>
                  </summary>
                  <p class="pb-6 pr-12 text-base leading-relaxed text-olive/75">{f.a}</p>
                </details>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <!-- RIGHT: sticky widget -->
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <BookingWidget product="Kids Club session" productId="kids-club" basePrice="from €60" />
      </aside>

    </div>
  </section>

  <!-- Why parents choose Peak strip -->
  <section class="bg-brown text-salt">
    <div class="mx-auto max-w-screen-2xl px-6 py-20 md:py-24">
      <h2 class="text-3xl md:text-5xl">Why parents pick us.</h2>
      <p class="mt-4 max-w-2xl text-lg text-salt/70">Built on empathy, teamwork, and a bit of healthy competition.</p>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-3xl border border-salt/10 p-6">
          <p class="meta text-salt/50">Small groups</p>
          <p class="mt-3 text-base leading-relaxed text-salt/85">Max 4 in mini-groups, max 6 in the 5+ groups. Every kid actually gets coached.</p>
        </div>
        <div class="rounded-3xl border border-salt/10 p-6">
          <p class="meta text-salt/50">Longer sessions</p>
          <p class="mt-3 text-base leading-relaxed text-salt/85">Three hours per session for 8+ kids — proper time to explore, learn, and holiday.</p>
        </div>
        <div class="rounded-3xl border border-salt/10 p-6">
          <p class="meta text-salt/50">Coaching that sticks</p>
          <p class="mt-3 text-base leading-relaxed text-salt/85">Patient, empathetic, inspirational. State-of-the-art teaching techniques delivered by people who give a damn.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Return-to-booking strip -->
  <section class="border-t border-olive/10 bg-snow">
    <div class="mx-auto flex max-w-screen-2xl flex-col items-start justify-between gap-4 px-6 py-8 md:flex-row md:items-center">
      <p class="text-lg">Ready to enrol in the Kids Club?</p>
      <a
        href="#top"
        class="inline-flex items-center rounded-full bg-yellow px-6 py-3 font-display text-sm font-bold uppercase tracking-tight text-olive-deep no-underline transition hover:bg-salt"
      >
        Back to booking ↑
      </a>
    </div>
  </section>
</BaseLayout>
