---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';
import Section from '../../components/ui/Section.astro';
import ArchEmbed from '../../components/booking/ArchEmbed.astro';

// 7 levels, ordered beginner → expert. Each has a one-line self-assessment
// and a short list of capabilities the skier can already do at that level.
const levels = [
  {
    name: 'Beginner',
    headline: 'Total beginner, never skied before.',
    bullets: [
      "You'll learn how to use the equipment",
      'Balance and slide on a nursery slope',
      'Make a snowplough shape while sliding',
      'Use magic carpets',
    ],
  },
  {
    name: 'Improver',
    headline: 'Can snowplough turn and stop competently on a green run.',
    bullets: [
      'Get up yourself after falling',
      'Snowplough traverse',
      'Follow the instructor without cutting corners',
      'Use chairlifts (accompanied) and bubble lifts',
    ],
  },
  {
    name: 'Basic Intermediate',
    headline: 'Comfortable snowplough turning on greens and easy blues. Ready to learn parallel.',
    bullets: [
      'Balance on the outside ski',
      'Side-slip, may leave the uphill ski behind',
      'Parallel traverse with the lower ski gripping',
      'Use chairlifts independently',
    ],
  },
  {
    name: 'Intermediate',
    headline: 'Exploring all blue runs and easy reds, parallel-turning with confidence.',
    bullets: [
      'Direct side-slip, controlling both skis simultaneously',
      'Ski within a corridor on slope, controlling speed and line',
      'Hold posture on steeper slopes',
      'Use all lifts',
    ],
  },
  {
    name: 'Basic Advanced',
    headline: 'Comfortable on most reds. Want to handle changing snow and steeper slopes.',
    bullets: [
      'Lift the inside ski at the fall line through to end of turn',
      'Diagonal side-slip, controlling fore-and-aft movement',
      'Learning short turns and pole plant',
      'Navigating the ski area',
    ],
  },
  {
    name: 'Advanced',
    headline: 'Happy on any colour. Working on grippy short turns, starting to carve longer turns.',
    bullets: [
      'Ski a narrow corridor, controlling speed and line',
      'Maintain ski-to-snow contact at all times',
      'Roll edge-to-edge on a green slope, two clean tracks',
      'Ski a funnel from short to medium to long radius',
      'Lap runs independently and lead around the area',
    ],
  },
  {
    name: 'Expert',
    headline: 'All-mountain confidence. Pushing your level on piste, off-piste, moguls, touring.',
    bullets: [
      'Linked turns in easy moguls',
      'Clean carving on reds and blacks',
      'Flowing turns in off-piste snow',
      'Avalanche scale and equipment',
      'Navigate variables, lead in trees or off-piste',
      'Deal with emergencies; attempt green and blue freestyle features',
    ],
  },
];

// Tightened from the Squarespace FAQ (21 → 11 most-asked). Founder voice; the
// rest can come back later if needed.
const faqs = [
  {
    q: 'How long are the lessons?',
    a: 'We recommend 3-hour sessions. 2-hour sessions also available, see each course page for the specifics.',
  },
  {
    q: 'How big are the groups?',
    a: 'Eight max in any group. With group lessons we usually run multiple groups alongside, so we can shuffle people to the right level on day one.',
  },
  {
    q: "What if I'm not the right level?",
    a: "We'll move you into the right group if one's running, or offer the equivalent in private lessons for the remaining time.",
  },
  {
    q: 'Is the lift pass included?',
    a: "Nope. Lift passes are bought from the local lift offices or via your tour operator, children 5 and under ski free.",
  },
  {
    q: 'Where do we meet?',
    a: 'Meeting points are in our locations section, and we send full details when you book. You\'ll be in direct contact with your instructor or one of our coordinators. Lost? Ring +44 1483 616 522.',
  },
  {
    q: 'What should I wear and bring?',
    a: 'Clothes, definitely wear clothes. We rate Peak Performance for outerwear and Coal Headwear for hats. Helmets are compulsory for children and strongly recommended for everyone else.',
  },
  {
    q: 'Equipment hire?',
    a: 'We work with a few local rental partners, see the Partners section for the list, and the trusted-partner discount when you book through us.',
  },
  {
    q: 'Do your instructors speak English?',
    a: "Yes. They're either from the UK or speak fluently.",
  },
  {
    q: 'Cancellation?',
    a: "Give us a month's notice and you're 100% refunded, no questions asked. Cancel inside a month and we'll issue lesson credit you can use later (or gift to someone).",
  },
  {
    q: 'What if the weather turns?',
    a: 'We run lessons in all weather. If the lifts and pistes are officially closed, we\'ll issue a statement of fact letter you can take to your insurer.',
  },
  {
    q: 'Insurance?',
    a: 'You arrange your own. Winter sports cover is essential; in France, Carte Neige can be bought at the lift office with your pass. We carry public liability cover up to £10m.',
  },
];
---

<BaseLayout
  title="Adult group lessons · Peak Snowsports"
  description="Small-group adult ski lessons across Morzine, Avoriaz, Les Gets and Chatel. Seven levels from total beginner to expert. Eight max per group."
>
  <Hero
    kicker="Lessons · Adult group"
    headline="Small groups. Real progression."
    sub="Learn alongside other adults at your level. Eight max per group. Seven levels from total beginner to expert, find yours below."
    primaryCta={{ href: '#book', label: 'Check availability' }}
    secondaryCta={{ href: '#levels', label: 'Find your level' }}
    variant="full"
    video="/videos/technique-garlands.mp4"
    videoPoster="/videos/technique-garlands-poster.jpg"
    imageAlt="A coach leading a group through a garlands drill above Avoriaz."
  />

  <!-- Welcome / overview -->
  <Section kicker="Welcome" title="Small groups. You still feel like an individual.">
    <div class="grid items-start gap-12 lg:grid-cols-[1fr_minmax(0,460px)] lg:gap-20">
      <div class="space-y-10">
        <p class="text-xl font-medium leading-snug text-olive md:text-2xl">
          Real progression through seven levels, coached by the same people who teach other ski schools' instructors. Eight skiers max. You learn faster because we never lose track of you.
        </p>

        <dl class="grid gap-x-6 gap-y-6 border-y border-olive/10 py-6 sm:grid-cols-3">
          <div>
            <dt class="meta text-olive/50">Group size</dt>
            <dd class="mt-1 font-display text-2xl font-bold tracking-tight">8 max</dd>
          </div>
          <div>
            <dt class="meta text-olive/50">Session length</dt>
            <dd class="mt-1 font-display text-2xl font-bold tracking-tight">3 hours</dd>
          </div>
          <div>
            <dt class="meta text-olive/50">Levels</dt>
            <dd class="mt-1 font-display text-2xl font-bold tracking-tight">7</dd>
          </div>
        </dl>

        <div class="space-y-5 text-base leading-relaxed text-olive/75 md:text-lg">
          <p>
            Lessons run across the Portes du Soleil. We usually run several groups in parallel so we can shuffle people on day one if a level isn't quite right.
          </p>
          <p>
            Our coaches are all fully qualified, and most teach on our instructor courses too. You're learning from the people the next generation of ski instructors learn from.
          </p>
        </div>
      </div>

      <div class="space-y-4">
        <div class="rounded-3xl border border-olive bg-cream p-6">
          <p class="meta text-olive">Standard session</p>
          <p class="mt-2 font-display text-xl font-bold tracking-tight">3 hours · 8 max</p>
          <p class="mt-1 text-sm text-olive/70">2-hour sessions also available, check each course page.</p>
        </div>
        <div class="rounded-3xl border border-olive bg-cream p-6">
          <p class="meta text-olive">Where</p>
          <p class="mt-2 font-display text-xl font-bold tracking-tight">Morzine · Avoriaz · Les Gets · Chatel</p>
          <p class="mt-1 text-sm text-olive/70">Meeting points by resort, sent with your booking.</p>
        </div>
        <div class="rounded-3xl border border-olive bg-cream p-6">
          <p class="meta text-olive">Cancellation</p>
          <p class="mt-2 font-display text-xl font-bold tracking-tight">Refundable up to 1 month</p>
          <p class="mt-1 text-sm text-olive/70">Inside a month, we issue lesson credit you can use later.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Find your level -->
  <Section id="levels" kicker="Find your level" title="Where are you on the mountain?">
    <p class="max-w-3xl text-lg leading-relaxed text-olive/80 md:text-xl">
      Read down until something sounds like you. If you're between two, pick the lower, we move skiers up on day one when it's a clear fit.
    </p>
    <ol class="mt-16 space-y-16">
      {levels.map((l, i) => (
        <li class="border-t border-olive/10 pt-10">
          <div class="grid gap-6 md:grid-cols-[5rem_1fr]">
            <span class="meta inline-flex h-14 w-14 items-center justify-center rounded-full bg-yellow text-olive-deep">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <p class="meta text-olive/50">Level {i + 1}</p>
              <h3 class="mt-1 font-display text-2xl font-bold tracking-tight md:text-4xl">{l.name}</h3>
              <p class="mt-4 max-w-2xl text-lg leading-relaxed text-olive/80">{l.headline}</p>
              <ul class="mt-6 grid gap-3 sm:grid-cols-2">
                {l.bullets.map((b) => (
                  <li class="flex gap-3 text-base leading-relaxed text-olive/80">
                    <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-yellow" />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <!-- Ready to book -->
  <Section id="book" kicker="Ready to book" title="Pick your level. Pick a date.">
    <p class="max-w-3xl text-lg leading-relaxed text-olive/80 md:text-xl">
      Live availability across all our group products. Hold your place with a small deposit.
    </p>
    <div class="mt-12">
      <ArchEmbed path="/products" height="900px" />
    </div>
    <p class="meta mt-6 text-olive/55">
      Booking delivered by Arch. Trouble loading? <a href="/contact" class="underline-offset-4 hover:bg-yellow hover:underline">Get in touch</a> and we'll book you in directly.
    </p>
  </Section>

  <!-- FAQs -->
  <Section kicker="FAQs" title="The usual questions.">
    <div class="max-w-3xl">
      <dl class="divide-y divide-olive/10 border-y border-olive/10">
        {faqs.map((f) => (
          <div class="py-6">
            <dt class="font-display text-xl font-bold tracking-tight md:text-2xl">{f.q}</dt>
            <dd class="mt-3 text-base leading-relaxed text-olive/80 md:text-lg">{f.a}</dd>
          </div>
        ))}
      </dl>
      <p class="meta mt-10 text-olive/55">
        Still not sure?
        <a href="tel:+441483616522" class="underline-offset-4 hover:bg-yellow hover:underline">+44 1483 616 522</a>
        or
        <a href="/contact" class="underline-offset-4 hover:bg-yellow hover:underline">drop us a line</a>.
      </p>
    </div>
  </Section>
</BaseLayout>
