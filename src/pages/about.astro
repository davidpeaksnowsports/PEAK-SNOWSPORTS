---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import Section from '../components/ui/Section.astro';
import heroImage from '../assets/images/hero-about.jpg';

const stats = [
  { value: '20,000+', label: 'Clients taught' },
  { value: '17', label: 'Instructors' },
  { value: '4', label: 'Resorts' },
  { value: '12+', label: 'Seasons' },
];

const whyPeak = [
  {
    title: 'Small groups, proper attention.',
    body:
      "We cap our group sizes so every client gets real coaching time — not a head count in a queue.",
  },
  {
    title: 'Coaches who can actually teach.',
    body:
      "Our team understands ski technique well enough to break it down into bite-sized pieces, demonstrate it cleanly, and adapt it to how you learn. Patience, humility and a bit of fun sit at the centre of how we deliver — because that's what makes lessons stick.",
  },
  {
    title: 'A team that shares the values.',
    body:
      "Every coach at Peak is a top-class professional who shares our passion for adventure and the way we like to do things. No phoning it in.",
  },
  {
    title: 'Taught in English.',
    body:
      "All our lessons are delivered by fluent English speakers, so nothing gets lost in translation.",
  },
  {
    title: 'We care about the mountains we work in.',
    body:
      "We're passionate about preserving the places we ski and making sure what we do does no harm. That isn't a marketing line — it shows up in the small decisions.",
    commitments: [
      'Our uniform is made without water-based dyes',
      'We car-share when moving instructors around the valley',
      'We launched the Sustainable Ski Lesson — a session designed to raise awareness and give clients practical actions they can take for the climate',
      'We donate to Montagne Verte, supporting their work protecting the Alps we love',
    ],
  },
];

// Brothers in motion — alternated so no two same-brother are adjacent
const motion = [
  { src: '/images/about/david-motion-1.jpg',  alt: 'David carving in snow spray' },
  { src: '/images/about/marc-motion-1.jpg',   alt: 'Marc on piste with a chairlift overhead' },
  { src: '/images/about/george-motion-1.jpg', alt: 'George airborne in front of an alpine face' },
  { src: '/images/about/george-motion-2.jpg', alt: 'George in deep powder' },
  { src: '/images/about/david-motion-2.jpg',  alt: 'David mid-carve under a clear blue sky' },
  { src: '/images/about/marc-motion-2.jpg',   alt: 'Marc on a powder turn' },
];

const brothers = [
  {
    name: 'George',
    photo: '/images/about/george-about.jpg',
    body:
      "George is the one who'll have you laughing halfway down your first run and somehow skiing better by the bottom of it. Endlessly patient, properly encouraging, and unfussed about whether you're six years old on a magic carpet or a nervous adult finally giving it a proper go — he meets you where you are. Off the clock, you'll find him deep in the Portes du Soleil somewhere, usually on a ski tour, usually with a camera.",
  },
  {
    name: 'Marc',
    photo: '/images/about/marc-about.jpg',
    body:
      "Marc is the coach people keep coming back for. He's got a knack for spotting the one small thing that's been holding your skiing back for years and quietly fixing it without making a fuss. Calm on the hill, sharp eye, and the kind of dry humour that makes a three-hour lesson feel like an hour. He's the brother most likely to push you a little further than you thought you could go — and most likely to be right about it.",
  },
  {
    name: 'David',
    photo: '/images/about/david-about.jpg',
    body:
      "David is the one who keeps the wheels turning behind the scenes. Building the business, looking after the team, and making sure that when you turn up for a lesson, everything from the booking to the boots to the coach standing in front of you is exactly as it should be. He's also out on the snow plenty — and if you've ever had a lesson with him, you'll know he treats every client like they're the only one on his books that week.",
  },
];
---

<BaseLayout title="About — Peak Snowsports">
  <Hero
    kicker="About"
    headline="We don't run lessons. We build skiers."
    sub="Founded by three brothers obsessed with the mountains. Built around coaching that actually cares."
    variant="full"
    image={heroImage}
    imageAlt="A snow-laden ridge in the Portes du Soleil under a clear winter sky."
  />

  <Section kicker="The story" title="Three brothers. One ski school.">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_minmax(0,460px)] lg:gap-20">
      <div class="space-y-6 text-lg leading-relaxed text-olive/80 md:text-xl">
        <p>
          Peak is a British-owned ski school in the Portes du Soleil, founded by three brothers — George, Marc and David Walton — who grew up obsessed with the mountains and turned that obsession into a business.
        </p>
        <p>
          We started Peak to build the ski school we wished existed. One where the coaching is genuinely excellent, the team actually cares, and a week with us feels less like a transaction and more like a few days spent with friends who happen to be very good at skiing.
        </p>
      </div>
      <figure class="overflow-hidden rounded-3xl bg-brown aspect-[4/5]">
        <img
          src="/images/about/three-brothers-image.jpg"
          alt="A lone Peak skier carving deep powder."
          loading="lazy"
          class="h-full w-full object-cover"
        />
      </figure>
    </div>
  </Section>

  <Section>
    <p class="meta text-yellow">Where we ski</p>
    <h2 class="mt-6 text-5xl leading-[0.95] tracking-tight md:text-7xl lg:text-8xl">
      Four resorts. One ski school.
    </h2>

    <p class="mt-10 max-w-3xl text-lg leading-relaxed text-olive/80">
      Based across four resorts in the Portes du Soleil, we run lessons for every level — first-timers finding their feet, families, kids, intermediates breaking out of a rut, and stronger skiers chasing off-piste and ski touring. We also run our <a href="/gap-course" class="underline-offset-4 hover:text-yellow hover:underline">BASI Level 1 and 2 GAP instructor course</a> out of Avoriaz for the next generation of coaches coming through.
    </p>

    <ul class="mt-16 divide-y divide-olive/10 border-y border-olive/10">
      {[
        { name: 'Morzine', tag: 'Family-friendly Alpine village', href: '/resorts/morzine' },
        { name: 'Avoriaz', tag: 'Car-free, ski-in / ski-out', href: '/resorts/morzine' },
        { name: 'Les Gets', tag: 'Quieter, gentler, family-leaning', href: '/resorts/les-gets' },
        { name: 'Chatel', tag: 'Linga snow, Super Chatel relaxed', href: '/resorts/chatel' },
      ].map((r) => (
        <li>
          <a
            href={r.href}
            class="group flex items-baseline gap-4 py-8 no-underline transition md:gap-8 md:py-10"
          >
            <span class="font-display text-4xl font-bold tracking-tight transition group-hover:text-yellow md:text-6xl lg:text-7xl">
              {r.name}.
            </span>
            <span class="meta hidden text-olive/50 md:inline">{r.tag}</span>
            <span class="ml-auto font-display text-2xl transition group-hover:translate-x-2 group-hover:text-yellow md:text-3xl">→</span>
          </a>
        </li>
      ))}
    </ul>
  </Section>

  <Section kicker="How we coach" title="You at the centre.">
    <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,520px)_1fr] lg:gap-20">
      <figure class="overflow-hidden rounded-3xl bg-brown lg:order-first">
        <img
          src="/images/about/you-at-the-centre.jpg"
          alt="A Peak instructor and client pause on piste, an Alpine peak rising behind them."
          loading="lazy"
          class="aspect-[4/5] h-full w-full object-cover"
        />
      </figure>
      <p class="text-lg leading-relaxed text-olive/80 md:text-xl">
        What ties it all together is a coaching philosophy that puts you at the centre. Our team — alongside Tom, Eilidh and a wider crew of fully qualified instructors — works to a skills-based approach. Which is a fancy way of saying we figure out what you actually need and teach to that, rather than running you through a script.
      </p>
    </div>
  </Section>

  <Section kicker="Why Peak" title="The short version.">
    <div class="space-y-4 font-display text-4xl font-bold leading-[1.05] tracking-tight md:text-6xl">
      <p>Time. Team. Experience.</p>
      <p>We don't run lessons. We build skiers.</p>
      <p>Experiences, not transactions.</p>
    </div>

    <p class="meta mt-16 text-olive/50">And here's the longer one.</p>

    <ol class="mt-12 space-y-16">
      {whyPeak.map((r, i) => (
        <li class="border-t border-olive/10 pt-10">
          <div class="grid gap-6 md:grid-cols-[5rem_1fr]">
            <span class="meta text-olive/40">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="font-display text-2xl font-bold tracking-tight md:text-3xl">{r.title}</h3>
              <p class="mt-4 max-w-2xl text-lg leading-relaxed text-olive/80">{r.body}</p>
              {r.commitments && (
                <ul class="mt-6 max-w-2xl space-y-3">
                  {r.commitments.map((c) => (
                    <li class="flex gap-3 text-base text-olive/70">
                      <span class="meta mt-1 shrink-0 text-yellow">&middot;</span>
                      <span>{c}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <Section kicker="By the numbers" title="A network, not a sole trader.">
    <div class="grid gap-y-10 gap-x-8 md:grid-cols-4">
      {stats.map((s) => (
        <div>
          <span class="inline-flex items-center rounded-full bg-yellow px-6 py-3 font-display text-3xl font-bold tracking-tight text-olive-deep md:text-4xl">
            {s.value}
          </span>
          <p class="meta mt-4 text-olive/60">{s.label}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section kicker="The brothers" title="George. Marc. David.">
    <div class="grid gap-12 md:grid-cols-3">
      {brothers.map((b) => (
        <div>
          <div class="aspect-[3/4] w-full overflow-hidden rounded-3xl bg-brown">
            <img src={b.photo} alt={b.name} class="h-full w-full object-cover" loading="lazy" />
          </div>
          <h3 class="mt-6 font-display text-3xl font-bold tracking-tight">{b.name}</h3>
          <p class="mt-4 text-base leading-relaxed text-olive/80">{b.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section kicker="On the mountain" title="Where they're happiest.">
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {motion.map((m) => (
        <figure class="overflow-hidden rounded-3xl bg-brown">
          <img
            src={m.src}
            alt={m.alt}
            loading="lazy"
            class="aspect-[4/3] h-full w-full object-cover transition duration-500 hover:scale-105"
          />
        </figure>
      ))}
    </div>
  </Section>

  <Section>
    <div class="border-t border-olive/10 pt-16">
      <p class="max-w-3xl text-lg leading-relaxed text-olive/80">
        We're a small, growing business and we like it that way. It means we know our clients, we know our team, and we can keep the standard high. Whether you're booking your first lesson or your fifteenth, the goal is the same — memorable moments on snow.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="/book"
          class="inline-flex items-center rounded-full bg-yellow px-8 py-4 font-display text-base font-bold uppercase tracking-tight text-olive-deep no-underline transition hover:bg-salt"
        >
          Come and ski with us →
        </a>
        <a
          href="/instructors"
          class="inline-flex items-center rounded-full border border-olive/30 px-8 py-4 font-display text-base font-bold uppercase tracking-tight no-underline transition hover:border-yellow hover:bg-yellow hover:text-olive-deep"
        >
          Meet the team
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
