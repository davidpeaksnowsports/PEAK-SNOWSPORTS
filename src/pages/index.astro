---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import InstructorCard from '../components/instructors/InstructorCard.astro';
import PostCard from '../components/journal/PostCard.astro';
import { LOREM } from '../lib/utils';

const resorts = [
  { name: 'Morzine', href: '/resorts/morzine', kicker: 'Resort 01' },
  { name: 'Chatel', href: '/resorts/chatel', kicker: 'Resort 02' },
  { name: 'Les Gets', href: '/resorts/les-gets', kicker: 'Resort 03' },
];

const pillars = [
  { kicker: 'Time', title: 'Time invested in the client', body: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor.' },
  { kicker: 'Team', title: 'Time invested in our team', body: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam.' },
  { kicker: 'Experience', title: 'An experience, not a transaction', body: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis aute irure dolor.' },
];

const instructors = Array.from({ length: 6 }, (_, i) => ({
  name: `Instructor ${i + 1}`,
  resort: ['Morzine', 'Chatel', 'Les Gets'][i % 3],
  speciality: 'Private · Off-piste',
}));

const posts = Array.from({ length: 3 }, (_, i) => ({
  title: `Lorem ipsum dolor sit amet ${i + 1}`,
  category: ['Resort guides', 'Technique', 'Season updates'][i],
  author: 'George Walton',
  date: '12 Mar 2026',
}));
---

<BaseLayout>
  <Hero
    kicker="Morzine · Chatel · Les Gets"
    headline="Learn to ski. Properly."
    sub="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    primaryCta={{ href: '/book', label: 'Book a lesson' }}
    secondaryCta={{ href: '/gap-course', label: 'Explore the GAP Course' }}
    variant="full"
  />

  <Section kicker="Three resorts" title="One school. Three resorts in the Portes du Soleil.">
    <div class="grid gap-6 md:grid-cols-3">
      {resorts.map((resort) => (
        <Card href={resort.href} kicker={resort.kicker} title={resort.name}>
          {LOREM}
        </Card>
      ))}
    </div>
  </Section>

  <Section kicker="Why Peak" title="Time. Team. Experience.">
    <div class="grid gap-6 md:grid-cols-3">
      {pillars.map((pillar) => (
        <Card kicker={pillar.kicker} title={pillar.title}>
          {pillar.body}
        </Card>
      ))}
    </div>
  </Section>

  <Section kicker="The team" title="25+ instructors. No anonymous ESF badges.">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-6">
      {instructors.map((i) => (
        <InstructorCard name={i.name} resort={i.resort} speciality={i.speciality} />
      ))}
    </div>
    <div class="mt-12">
      <a href="/instructors" class="meta text-yellow no-underline hover:underline">Meet the full team →</a>
    </div>
  </Section>

  <Section kicker="Testimonials" title="Lorem ipsum dolor sit amet.">
    <div class="grid gap-12 md:grid-cols-2">
      {[1, 2].map((n) => (
        <figure class="border-l border-yellow pl-8">
          <blockquote class="text-2xl font-semibold leading-snug md:text-3xl">
            "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
          </blockquote>
          <figcaption class="meta mt-6 text-salt/60">Client {n} · Private lessons · Morzine 2025</figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <Section kicker="From the journal" title="Words from the team.">
    <div class="grid gap-12 md:grid-cols-3">
      {posts.map((p) => (
        <PostCard title={p.title} category={p.category} author={p.author} date={p.date} href="/journal" />
      ))}
    </div>
  </Section>

  <Section kicker="Newsletter" title="Get a season briefing every month.">
    <form class="flex max-w-xl flex-col gap-4 md:flex-row">
      <input
        type="email"
        placeholder="email@example.com"
        class="flex-1 border-b border-salt/30 bg-transparent px-2 py-3 text-lg placeholder:text-salt/40 focus:border-yellow focus:outline-none"
        aria-label="Email"
      />
      <button class="bg-yellow px-6 py-3 text-sm font-semibold uppercase tracking-wider text-navy-deep hover:bg-salt">
        Subscribe
      </button>
    </form>
  </Section>
</BaseLayout>
