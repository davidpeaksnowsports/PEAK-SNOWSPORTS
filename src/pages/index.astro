---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import InstructorCard from '../components/instructors/InstructorCard.astro';
import PostCard from '../components/journal/PostCard.astro';
import { formatDate, readingTime } from '../lib/utils';
import heroImage from '../assets/images/hero-home.jpg';

const allInstructors = await getCollection('instructors', ({ data }) => !data.draft);
const instructorStrip = allInstructors
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 6);

const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const resorts = [
  {
    name: 'Morzine-Avoriaz',
    href: '/resorts/morzine',
    kicker: 'Resort 01',
    body: 'The home of Peak. A proper alpine town with bars, restaurants and direct access to Avoriaz and the 600+ km Portes du Soleil. Family-friendly, with terrain for every level.',
  },
  {
    name: 'Châtel',
    href: '/resorts/chatel',
    kicker: 'Resort 02',
    body: 'The quieter end of the Portes du Soleil. Linga snow gets it early, Super Châtel stays mellow for learners. A working alpine village with the kind of pace you actually want on holiday.',
  },
  {
    name: 'Les Gets',
    href: '/resorts/les-gets',
    kicker: 'Resort 03',
    body: 'Gentle, pretty, family-leaning. Tree-lined runs, a long-standing race scene, and easy access to the wider Portes du Soleil. The friendly door into the linked area.',
  },
];

const pillars = [
  {
    kicker: 'Premium',
    title: 'Experiences. Not transactions.',
    body: 'Lessons that become moments. A team committed to taking you out of your comfort zone and into something worth remembering.',
  },
  {
    kicker: 'Personal',
    title: 'Small groups. Real attention.',
    body: 'Max six skiers in a group. Max four in the mini beginners. Kids’ lessons sized to age, three hours up to seven, four hours after.',
  },
  {
    kicker: 'Professional',
    title: 'The team that teaches the teachers.',
    body: 'Every instructor holds the highest qualification in their country plus a full French Carte Pro. Led by ski instructor examiners, the people who train other schools’ staff.',
  },
];

---

<BaseLayout>
  <Hero
    kicker="Moments on snow"
    headline="Learn to ski. Properly."
    sub="Experiences, not transactions. Across Morzine, Châtel and Les Gets."
    primaryCta={{ href: '/book', label: 'Book a lesson' }}
    secondaryCta={{ href: '/gap-course', label: 'Explore the GAP Course' }}
    tertiaryCta={{ href: '/ski-camps', label: 'Adult ski camps' }}
    variant="full"
    video="/videos/hero-home.mp4"
    videoPoster="/videos/hero-home-poster.jpg"
    image={heroImage}
    imageAlt="Where snow meets soul, Peak Snowsports brand film."
  />

  <Section kicker="Three resorts" title="One school. Three resorts in the Portes du Soleil.">
    <div class="grid gap-6 md:grid-cols-3">
      {resorts.map((resort) => (
        <Card href={resort.href} kicker={resort.kicker} title={resort.name}>
          {resort.body}
        </Card>
      ))}
    </div>
    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href="/book"
        class="inline-flex items-center rounded-full bg-yellow px-8 py-4 font-display text-sm font-bold uppercase tracking-tight text-olive-deep no-underline transition hover:bg-salt"
      >
        Book a lesson →
      </a>
    </div>
  </Section>

  <Section kicker="Why Peak" title="Premium. Personal. Professional.">
    <div class="grid gap-6 md:grid-cols-3">
      {pillars.map((pillar) => (
        <Card kicker={pillar.kicker} title={pillar.title}>
          {pillar.body}
        </Card>
      ))}
    </div>
    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href="/book"
        class="inline-flex items-center rounded-full bg-yellow px-8 py-4 font-display text-sm font-bold uppercase tracking-tight text-olive-deep no-underline transition hover:bg-salt"
      >
        Book a lesson →
      </a>
    </div>
  </Section>

  <Section kicker="The team" title="17+ instructors. No anonymous badges.">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-6">
      {instructorStrip.map((i) => (
        <InstructorCard
          name={i.data.name}
          resort={i.data.resorts[0]}
          role={i.data.role}
          photo={i.data.photo}
          href={`/instructors/${i.id}`}
        />
      ))}
    </div>
    <div class="mt-12">
      <a href="/instructors" class="meta text-yellow no-underline hover:underline">Meet the full team →</a>
    </div>
  </Section>

  <Section kicker="What clients say" title="Three years. Same family. Same answer.">
    <figure class="mx-auto max-w-4xl border-l border-yellow pl-8 md:pl-12">
      <blockquote class="text-2xl font-semibold leading-snug md:text-3xl">
        “This is our third year of booking lessons for our boys (now aged 11 and 7) with Peak and they loved it more than ever. George and Marc were fun, patient and so skilled in ensuring that our boys were safe and progressed well. Rachel was kind, patient and lovely with our complete beginner niece (aged 4), she progressed incredibly quickly in her 3-hour lesson. Thanks so much again, see you next time 🤙🏼”
      </blockquote>
      <figcaption class="meta mt-8 text-olive/60">Repeat client · Private &amp; kids’ lessons · Morzine</figcaption>
    </figure>
    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href="/book"
        class="inline-flex items-center rounded-full bg-yellow px-8 py-4 font-display text-sm font-bold uppercase tracking-tight text-olive-deep no-underline transition hover:bg-salt"
      >
        Book a lesson →
      </a>
    </div>
  </Section>

  <Section kicker="From the journal" title="Words from the team.">
    {latestPosts[0] && (
      <div class="mx-auto max-w-4xl">
        <PostCard
          title={latestPosts[0].data.title}
          category={latestPosts[0].data.category}
          author={latestPosts[0].data.author}
          date={formatDate(latestPosts[0].data.publishedAt)}
          href={`/journal/${latestPosts[0].id}`}
          hero={latestPosts[0].data.hero}
          readingMinutes={readingTime(latestPosts[0].body ?? '')}
          featured
        />
      </div>
    )}
    <div class="mt-10">
      <a href="/journal" class="meta text-yellow no-underline hover:underline">Read the journal →</a>
    </div>
  </Section>

  <Section kicker="Newsletter" title="Get a season briefing every month.">
    <form class="flex max-w-xl flex-col gap-4 md:flex-row">
      <input
        type="email"
        placeholder="email@example.com"
        class="flex-1 border-b border-olive/30 bg-transparent px-2 py-3 text-lg placeholder:text-olive/40 focus:border-yellow focus:outline-none"
        aria-label="Email"
      />
      <button class="rounded-full bg-yellow px-6 py-3 text-sm font-semibold uppercase tracking-wider text-olive-deep hover:bg-salt">
        Subscribe
      </button>
    </form>
  </Section>
</BaseLayout>
