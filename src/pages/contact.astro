---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import Section from '../components/ui/Section.astro';
import { LOREM } from '../lib/utils';

const routes = [
  { label: 'GAP enquiry', href: 'https://wa.me/?text=GAP%20enquiry', kicker: 'WhatsApp' },
  { label: 'Lesson enquiry', href: 'https://wa.me/?text=Lesson%20enquiry', kicker: 'WhatsApp' },
  { label: 'Partner enquiry', href: 'mailto:partners@peaksnowsports.com', kicker: 'Email' },
];
---

<BaseLayout title="Contact — Peak Snowsports">
  <Hero
    kicker="Contact"
    headline="Talk to us."
    sub={LOREM}
    variant="compact"
  />

  <Section>
    <div class="grid gap-16 md:grid-cols-2">
      <div>
        <h2 class="text-3xl font-semibold leading-tight md:text-4xl">Direct line to the right person.</h2>
        <ul class="mt-8 space-y-4">
          {routes.map((r) => (
            <li>
              <a href={r.href} class="group flex items-baseline gap-4 border-b border-salt/10 py-4 no-underline hover:text-yellow">
                <span class="meta text-salt/50 group-hover:text-yellow">{r.kicker}</span>
                <span class="flex-1 text-xl font-semibold">{r.label}</span>
                <span aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <form class="space-y-6" action="#" method="post">
        <label class="block">
          <span class="meta text-salt/60">Name</span>
          <input type="text" name="name" required class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 focus:border-yellow focus:outline-none" />
        </label>
        <label class="block">
          <span class="meta text-salt/60">Email</span>
          <input type="email" name="email" required class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 focus:border-yellow focus:outline-none" />
        </label>
        <label class="block">
          <span class="meta text-salt/60">Message</span>
          <textarea name="message" rows="5" class="mt-2 w-full border-b border-salt/30 bg-transparent py-3 focus:border-yellow focus:outline-none" />
        </label>
        <button type="submit" class="bg-yellow px-6 py-3 text-sm font-semibold uppercase tracking-wider text-olive-deep hover:bg-salt">
          Send
        </button>
      </form>
    </div>
  </Section>
</BaseLayout>
