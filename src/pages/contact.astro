---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import Section from '../components/ui/Section.astro';

const routes = [
  { label: 'GAP enquiry', href: 'https://wa.me/?text=GAP%20enquiry', kicker: 'WhatsApp' },
  { label: 'Lesson enquiry', href: 'https://wa.me/?text=Lesson%20enquiry', kicker: 'WhatsApp' },
  { label: 'Partner enquiry', href: 'mailto:partners@peaksnowsports.com', kicker: 'Email' },
  { label: '+44 1483 616 522', href: 'tel:+441483616522', kicker: 'Phone' },
];
---

<BaseLayout title="Contact · Peak Snowsports">
  <Hero
    kicker="Contact"
    headline="Talk to us."
    sub="Four direct lines to the right person, or drop us a note via the form. We reply within 30 minutes during office hours."
    variant="compact"
  />

  <Section>
    <div class="grid gap-16 md:grid-cols-2">
      <div>
        <h2 class="text-3xl font-semibold leading-tight md:text-4xl">Direct line to the right person.</h2>
        <ul class="mt-8 space-y-4">
          {routes.map((r) => (
            <li>
              <a href={r.href} class="group -mx-3 flex items-baseline gap-4 border-b border-olive/10 px-3 py-4 no-underline transition-colors hover:bg-yellow">
                <span class="meta text-olive/50 group-hover:text-olive-deep">{r.kicker}</span>
                <span class="flex-1 text-xl font-semibold">{r.label}</span>
                <span aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <form
        class="space-y-6"
        action="mailto:hello@peaksnowsports.com"
        method="post"
        enctype="text/plain"
      >
        <input type="hidden" name="Subject" value="Contact form, peaksnowsports.com" />
        <label class="block">
          <span class="meta text-olive/60">Name</span>
          <input type="text" name="Name" required class="mt-2 w-full border-b border-olive/30 bg-transparent py-3 focus:border-pink focus:outline-none" />
        </label>
        <label class="block">
          <span class="meta text-olive/60">Email</span>
          <input type="email" name="Email" required class="mt-2 w-full border-b border-olive/30 bg-transparent py-3 focus:border-pink focus:outline-none" />
        </label>
        <label class="block">
          <span class="meta text-olive/60">Message</span>
          <textarea name="Message" rows="5" required class="mt-2 w-full border-b border-olive/30 bg-transparent py-3 focus:border-pink focus:outline-none" />
        </label>
        <button type="submit" class="rounded-full bg-pink px-6 py-3 text-sm font-semibold uppercase tracking-wider text-snow transition hover:bg-olive">
          Send
        </button>
        <p class="meta text-olive/55">
          Submitting opens your default mail app with the message addressed to hello@peaksnowsports.com. Or email us directly any time.
        </p>
      </form>
    </div>
  </Section>
</BaseLayout>
